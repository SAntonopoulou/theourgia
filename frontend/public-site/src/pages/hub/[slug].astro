---
/**
 * Hub detail — per-order public homepage.
 *
 * Faithful port of ``Theourgia Hub.dc.html``. Per
 * ``agent_onboarding.md`` § Theourgia Hub.dc.html:
 *   · Route ``/hub/:slug``. Public chrome, page-scroll.
 *   · Hero with unicursal-star watermark + Latin motto + stats.
 *   · Public rites (only public ones from the schedule), order writings,
 *     officers (link to Profile), lineage descent, petition-to-join card,
 *     verified-hub key.
 *   · ``Membership`` is the admin half; this is the public half.
 *   · Petition-to-join writes a pending membership (real endpoint pending);
 *     hub key card runs a real signature check (pending §10.5).
 *
 * This build ships a single demo hub at /hub/ordo-theurgica until the
 * Hubs model + federation read-side land.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Rite {
  mon: string;
  day: string;
  title: string;
  time: string;
  place: string;
  tag: string;
  tagColor: string;
}
interface OrderWriting {
  kind: string;
  title: string;
  blurb: string;
  author: string;
  meta: string;
}
interface Officer {
  glyph: string;
  name: string;
  office: string;
  profileHref: string;
}
interface LineageNode {
  name: string;
  note: string;
  noteTone: "mute" | "success";
  attested: boolean;
}
interface HubData {
  slug: string;
  name: string;
  motto: string;
  mottoEn: string;
  eyebrow: string;
  about: string[];
  stats: { value: string; label: string }[];
  rites: Rite[];
  writings: OrderWriting[];
  officers: Officer[];
  lineage: LineageNode[];
  hubKey: string;
  nextReading: string;
  petitionBlurb: string;
}

export function getStaticPaths() {
  const HUBS: HubData[] = [
    {
      slug: "ordo-theurgica",
    name: "Ordo Theurgica",
    motto: "Ascensus per disciplinam",
    mottoEn: "ascent through discipline",
    eyebrow: "Hermetic order · founded 2009 · 47 initiates",
    about: [
      "Ordo Theurgica is a small order. We are not a school of correspondence courses, nor a social club. We meet to do the work of theurgy as the Neoplatonists understood it — the soul's ascent through ritual, contemplation, and the disciplined keeping of a record — and we hold one another to that standard.",
      "Initiates progress through three degrees, each marked by attestation rather than payment. What is taught at one degree is sealed from those below it, in the old manner. The order federates with the wider Theourgia network for its weekly rites, but its inner work remains its own.",
    ],
    stats: [
      { value: "47", label: "Initiates" },
      { value: "3", label: "Degrees" },
      { value: "2009", label: "Founded" },
      { value: "Weekly", label: "Network rites" },
    ],
    rites: [
      { mon: "Jun", day: "21", title: "Solstice Vigil — Invocation of Helios", time: "20:00", place: "Network · in unison", tag: "Open", tagColor: "var(--success)" },
      { mon: "Jun", day: "29", title: "Gnostic Mass — open celebration", time: "18:00", place: "Isis-Urania · in person", tag: "Visitors", tagColor: "var(--ink-soft)" },
      { mon: "Jul", day: "02", title: "Lecture — Reading the First Oracle", time: "19:30", place: "Network · public", tag: "Open", tagColor: "var(--success)" },
    ],
    writings: [
      { kind: "Notice", title: "On the admission of the Autumn cohort", blurb: "The officers will read petitions at the equinox. A word on what we look for, and what we do not.", author: "The Hierophant", meta: "12 Jun" },
      { kind: "Essay", title: "Why this order keeps a written record", blurb: "The magical record is not bureaucracy. It is the discipline that distinguishes practice from reverie.", author: "Theophrastos", meta: "4 Jun · 9 min" },
    ],
    officers: [
      { glyph: "Θ", name: "Theophrastos", office: "Hierophant · 3°", profileHref: "/profile" },
      { glyph: "Δ", name: "Demetra", office: "Hiereus · 2°", profileHref: "/profile" },
      { glyph: "Φ", name: "Philon", office: "Keeper of the Record", profileHref: "/profile" },
    ],
    lineage: [
      { name: "The Neoplatonic Academy", note: "Claimed descent · contemplative", noteTone: "mute", attested: false },
      { name: "Hermetic Order of the Golden Dawn", note: "Attested · ritual transmission", noteTone: "success", attested: true },
      { name: "Ordo Theurgica", note: "Founded 2009 · this order", noteTone: "mute", attested: false },
    ],
    hubKey: "ed25519 · 7C19·A4F0·…·2BD6",
    nextReading: "Next reading: Autumn Equinox",
      petitionBlurb: "Membership opens twice yearly, at the equinoxes. A petition is read by the officers; a member must attest for you.",
    },
  ];
  return HUBS.map((hub) => ({ params: { slug: hub.slug }, props: { hub } }));
}

const { hub } = Astro.props as { hub: HubData };

const MAXW = "1080px";
---

<BaseLayout title={`${hub.name} — Theourgia`}>
  <div style="min-height:100vh;background:var(--bg);color:var(--ink);font-family:var(--font-serif)">

    <!-- PUBLIC HEADER (hub-scoped) -->
    <header style="border-bottom:1px solid var(--line);background:var(--bg);position:sticky;top:0;z-index:20">
      <div style={`max-width:${MAXW};margin:0 auto;padding:16px 28px;display:flex;align-items:center;gap:22px`}>
        <a href={`/hub/${hub.slug}`} style="display:flex;align-items:center;gap:12px;text-decoration:none;color:inherit">
          <svg width="30" height="30" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <circle cx="20" cy="20" r="18" stroke="var(--accent)" stroke-width="1.3"></circle>
            <circle cx="20" cy="20" r="12.5" stroke="var(--accent)" stroke-width=".8" opacity=".6"></circle>
            <path d="M20 6.5 L20 33.5 M6.5 20 L33.5 20" stroke="var(--accent)" stroke-width="1"></path>
            <circle cx="20" cy="20" r="3.4" fill="var(--accent)"></circle>
          </svg>
          <span style="font-family:var(--font-display);font-size:19px;letter-spacing:.02em">{hub.name}</span>
        </a>
        <nav class="om-pubnav" style="display:flex;gap:20px;margin-left:6px;font-family:var(--font-ui);font-size:13.5px;color:var(--ink-soft)">
          <a href="#about" class="pub-nav-link" style="text-decoration:none;color:inherit">About</a>
          <a href="#rites" class="pub-nav-link" style="text-decoration:none;color:inherit">Rites</a>
          <a href="#writings" class="pub-nav-link" style="text-decoration:none;color:inherit">Writings</a>
          <a href="#lineage" class="pub-nav-link" style="text-decoration:none;color:inherit">Lineage</a>
        </nav>
        <div style="margin-left:auto;display:flex;align-items:center;gap:11px">
          <div role="group" aria-label="Theme" class="om-pubseg theme-cycler" style="display:flex;gap:2px;padding:3px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2)">
            <button type="button" data-theme-pick="base" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Base</button>
            <button type="button" data-theme-pick="hellenic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Hel</button>
            <button type="button" data-theme-pick="thelemic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Thel</button>
          </div>
          <button type="button" data-mode-toggle aria-label="Toggle light and dark" class="mode-toggle" style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2);color:var(--ink-soft);cursor:pointer">
            <span data-mode-icon aria-hidden="true" style="display:inline-flex"></span>
          </button>
          <button type="button" class="petition-cta" style="padding:8px 16px;border-radius:var(--r-md);background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-weight:700;font-size:13px;white-space:nowrap;border:none;cursor:pointer">Petition to join</button>
        </div>
      </div>
    </header>

    <!-- HERO -->
    <section id="about" style="border-bottom:1px solid var(--line);background:var(--bg-2);position:relative;overflow:hidden">
      <div aria-hidden="true" style="position:absolute;right:-80px;top:-60px;width:360px;height:360px;opacity:.5;pointer-events:none">
        <svg width="100%" height="100%" viewBox="0 0 200 200" fill="none">
          <circle cx="100" cy="100" r="92" stroke="var(--accent-soft)" stroke-width="1"></circle>
          <circle cx="100" cy="100" r="70" stroke="var(--accent-soft)" stroke-width="1"></circle>
          <path d="M100 14 L122 78 L188 78 L134 118 L156 184 L100 142 L44 184 L66 118 L12 78 L78 78 Z" stroke="var(--accent-soft)" stroke-width="1" fill="none"></path>
        </svg>
      </div>
      <div style={`max-width:${MAXW};margin:0 auto;padding:54px 28px 46px;position:relative`}>
        <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:16px">{hub.eyebrow}</div>
        <h1 style="font-family:var(--font-display);font-weight:700;font-size:clamp(36px,5.5vw,58px);line-height:1.05;margin:0 0 8px;letter-spacing:-.01em">{hub.name}</h1>
        <div style="font-family:var(--font-display);font-style:italic;font-size:21px;color:var(--ink-soft);margin-bottom:22px">{hub.motto} — {hub.mottoEn}.</div>
        <p style="font-size:18px;line-height:1.62;color:var(--ink-soft);max-width:64ch;margin:0 0 26px">{hub.about[0]}</p>
        <div style="display:flex;gap:26px;flex-wrap:wrap">
          {hub.stats.map((s, i) => (
            <>
              {i > 0 ? <div style="width:1px;background:var(--line)"></div> : null}
              <div>
                <div style="font-family:var(--font-display);font-size:26px;line-height:1">{s.value}</div>
                <div style="font-family:var(--font-ui);font-size:11.5px;color:var(--ink-mute);margin-top:2px">{s.label}</div>
              </div>
            </>
          ))}
        </div>
      </div>
    </section>

    <!-- BODY -->
    <section>
      <div style={`max-width:${MAXW};margin:0 auto;padding:42px 28px 72px;display:flex;gap:40px;align-items:flex-start;flex-wrap:wrap`}>

        <!-- LEFT -->
        <div style="flex:2 1 440px;min-width:0">

          <h2 style="font-family:var(--font-display);font-size:25px;margin:0 0 14px">What we are</h2>
          <p style="font-size:16px;line-height:1.7;color:var(--ink-soft);margin:0 0 14px">{hub.about[0]}</p>
          <p style="font-size:16px;line-height:1.7;color:var(--ink-soft);margin:0 0 30px">{hub.about[1]}</p>

          <h2 id="rites" style="font-family:var(--font-display);font-size:25px;margin:0 0 6px">Public rites</h2>
          <p style="font-family:var(--font-ui);font-size:12.5px;color:var(--ink-mute);margin:0 0 18px">Open to visitors in good standing. The inner rites are not listed.</p>
          <div style="display:flex;flex-direction:column;border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden;background:var(--bg-2);margin-bottom:34px">
            {hub.rites.map((r, i) => (
              <div class="hub-rite" style={`display:flex;gap:18px;padding:18px 22px${i < hub.rites.length - 1 ? ";border-bottom:1px solid var(--line)" : ""};align-items:center`}>
                <div style="display:flex;flex-direction:column;align-items:center;width:54px;flex:none">
                  <span style="font-family:var(--font-ui);font-size:10px;text-transform:uppercase;color:var(--ink-mute)">{r.mon}</span>
                  <span style="font-family:var(--font-display);font-size:24px;line-height:1.05">{r.day}</span>
                </div>
                <div style="flex:1;min-width:0">
                  <div style="font-family:var(--font-display);font-size:18px;line-height:1.2">{r.title}</div>
                  <div style="display:flex;gap:13px;flex-wrap:wrap;font-family:var(--font-ui);font-size:12px;color:var(--ink-mute);margin-top:3px">
                    <span>{r.time}</span>
                    <span>{r.place}</span>
                  </div>
                </div>
                <span style={`font-family:var(--font-ui);font-size:11.5px;color:${r.tagColor};padding:3px 11px;border:1px solid var(--line);border-radius:999px;flex:none`}>{r.tag}</span>
              </div>
            ))}
          </div>

          <h2 id="writings" style="font-family:var(--font-display);font-size:25px;margin:0 0 18px">From the order</h2>
          <div style="display:flex;flex-direction:column;gap:18px">
            {hub.writings.map((w) => (
              <a href="/essay" class="hub-writing" style="display:block;border:1px solid var(--line);border-radius:var(--r-lg);padding:20px 22px;background:var(--bg-2);text-decoration:none;color:inherit">
                <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:7px">{w.kind}</div>
                <div style="font-family:var(--font-display);font-size:20px;line-height:1.2;margin-bottom:7px">{w.title}</div>
                <p style="font-size:14.5px;line-height:1.55;color:var(--ink-soft);margin:0 0 9px">{w.blurb}</p>
                <div style="font-family:var(--font-ui);font-size:12px;color:var(--ink-mute)">By {w.author} · {w.meta}</div>
              </a>
            ))}
          </div>

        </div>

        <!-- RIGHT -->
        <aside style="flex:1 1 270px;min-width:0;display:flex;flex-direction:column;gap:18px">

          <!-- petition -->
          <div style="background:var(--bg-2);border:1px solid var(--line-2);border-radius:var(--r-lg);padding:20px">
            <div style="font-family:var(--font-display);font-size:18px;margin-bottom:7px">Petition to join</div>
            <p style="font-family:var(--font-ui);font-size:12.5px;line-height:1.55;color:var(--ink-mute);margin:0 0 14px">{hub.petitionBlurb}</p>
            <button type="button" class="petition-begin" style="width:100%;padding:10px;border-radius:var(--r-md);background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-weight:700;font-size:13px;margin-bottom:9px;border:none;cursor:pointer">Begin a petition</button>
            <div style="display:flex;align-items:center;gap:7px;font-family:var(--font-ui);font-size:11.5px;color:var(--ink-mute);justify-content:center">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
              {hub.nextReading}
            </div>
          </div>

          <!-- lineage -->
          <div id="lineage" style="background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px">
            <div style="font-family:var(--font-ui);font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:13px">Lineage</div>
            <div style="display:flex;flex-direction:column;gap:0">
              {hub.lineage.map((node, i) => (
                i === 0 ? (
                  <div style="display:flex;gap:11px;align-items:flex-start;padding-bottom:11px">
                    <span style="font-family:var(--font-glyph);color:var(--accent);font-size:14px;flex:none;margin-top:1px">✦</span>
                    <div>
                      <div style="font-family:var(--font-serif);font-size:15px;color:var(--ink)">{node.name}</div>
                      <div style="font-family:var(--font-ui);font-size:11.5px;color:var(--ink-mute)">{node.note}</div>
                    </div>
                  </div>
                ) : (
                  <div style={`border-left:1px solid var(--line);margin-left:6px;padding:0 0 ${i < hub.lineage.length - 1 ? "11" : "0"}px 16px`}>
                    <div style="font-family:var(--font-serif);font-size:15px;color:var(--ink)">{node.name}</div>
                    {node.attested ? (
                      <div style="font-family:var(--font-ui);font-size:11.5px;color:var(--success);display:flex;align-items:center;gap:5px;margin-top:2px">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"></path><path d="M9 12l2 2 4-4"></path></svg>
                        {node.note}
                      </div>
                    ) : (
                      <div style="font-family:var(--font-ui);font-size:11.5px;color:var(--ink-mute)">{node.note}</div>
                    )}
                  </div>
                )
              ))}
            </div>
            <a href="/lineage" class="lineage-link" style="display:inline-flex;align-items:center;gap:7px;font-family:var(--font-ui);font-size:12.5px;color:var(--accent);margin-top:14px;text-decoration:none">See the full web →</a>
          </div>

          <!-- officers -->
          <div style="background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px">
            <div style="font-family:var(--font-ui);font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:14px">Officers</div>
            <div style="display:flex;flex-direction:column;gap:13px">
              {hub.officers.map((o) => (
                <a href={o.profileHref} class="officer-link" style="display:flex;align-items:center;gap:11px;text-decoration:none;color:inherit">
                  <span style="width:36px;height:36px;border-radius:50%;background:var(--accent-soft);border:1px solid var(--line-2);display:flex;align-items:center;justify-content:center;font-family:var(--font-glyph);color:var(--accent);font-size:16px;flex:none">{o.glyph}</span>
                  <div style="min-width:0;flex:1">
                    <div style="font-family:var(--font-display);font-size:15.5px;line-height:1.15;color:var(--ink)">{o.name}</div>
                    <div style="font-family:var(--font-ui);font-size:11.5px;color:var(--ink-mute)">{o.office}</div>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- verification -->
          <div style="background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r-lg);padding:16px 20px">
            <div style="display:flex;align-items:center;gap:9px;margin-bottom:9px">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"></path><path d="M9 12l2 2 4-4"></path></svg>
              <span style="font-family:var(--font-ui);font-size:13px;color:var(--ink)">Verified hub</span>
            </div>
            <p style="font-family:var(--font-ui);font-size:11.5px;line-height:1.5;color:var(--ink-mute);margin:0 0 9px">This order's identity and notices are cryptographically signed. Confirm the key before petitioning.</p>
            <div style="display:flex;align-items:center;gap:8px;padding:8px 11px;border:1px solid var(--line);border-radius:var(--r-md);background:var(--bg);font-family:var(--font-mono);font-size:11px;color:var(--ink-mute)">
              <span style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{hub.hubKey}</span>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- FOOTER -->
    <footer style="border-top:1px solid var(--line);background:var(--bg-2)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:34px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px`}>
        <div style="font-family:var(--font-display);font-style:italic;font-size:16px;color:var(--ink-soft)">{hub.motto}.</div>
        <div style="font-family:var(--font-ui);font-size:12px;color:var(--ink-mute)">A hub on the Theourgia network · federated</div>
      </div>
    </footer>

  </div>
</BaseLayout>

<style>
  .pub-nav-link { transition: color 0.15s ease; }
  .pub-nav-link:hover { color: var(--ink); }
  .petition-cta:hover, .petition-begin:hover { opacity: 0.9; }
  .mode-toggle:hover { color: var(--ink); }
  .hub-rite { transition: background-color 0.15s ease; }
  .hub-rite:hover { background: var(--bg-3); }
  .hub-writing { transition: border-color 0.15s ease; }
  .hub-writing:hover { border-color: var(--line-2); }
  .officer-link { transition: opacity 0.15s ease; }
  .officer-link:hover { opacity: 0.85; }
  .lineage-link { transition: gap 0.15s ease; }
  .lineage-link:hover { gap: 11px !important; }

  .seg-btn[data-selected="true"] {
    color: var(--ink) !important;
    background: var(--accent-soft) !important;
    border-color: var(--line-2) !important;
  }

  @media (max-width: 860px) { .om-pubnav { display: none !important; } }
  @media (max-width: 600px) { .om-pubseg { display: none !important; } }
</style>

<script>
  // Theme + mode wiring — mirrors PublicChrome.astro logic (cannot use the
  // component directly because Hub's header is hub-scoped, not the
  // Theourgia chrome).
  type Theme = "base" | "hellenic" | "thelemic";
  type Mode = "dark" | "light";

  const MOON_PATH = "M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z";
  const SUN_GROUP = `<circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path>`;

  const getTheme = (): Theme => {
    const v = document.documentElement.getAttribute("data-theme");
    return v === "hellenic" || v === "thelemic" ? v : "base";
  };
  const getMode = (): Mode =>
    document.documentElement.getAttribute("data-mode") === "light" ? "light" : "dark";

  const svgFor = (mode: Mode) =>
    mode === "dark"
      ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="${MOON_PATH}"></path></svg>`
      : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${SUN_GROUP}</svg>`;

  const sync = () => {
    const theme = getTheme();
    const mode = getMode();
    document.querySelectorAll<HTMLElement>("[data-theme-pick]").forEach((el) => {
      const matches = el.getAttribute("data-theme-pick") === theme;
      el.setAttribute("data-selected", matches ? "true" : "false");
      el.setAttribute("aria-pressed", matches ? "true" : "false");
    });
    document.querySelectorAll<HTMLElement>("[data-mode-icon]").forEach((el) => {
      el.innerHTML = svgFor(mode);
    });
  };

  const setTheme = (theme: Theme) => {
    document.documentElement.setAttribute("data-theme", theme);
    try { localStorage.setItem("theourgia.theme", theme); } catch (_) { /* noop */ }
    sync();
  };
  const setMode = (mode: Mode) => {
    document.documentElement.setAttribute("data-mode", mode);
    try { localStorage.setItem("theourgia.mode", mode); } catch (_) { /* noop */ }
    sync();
  };

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    if (!target) return;
    const themePick = target.closest<HTMLElement>("[data-theme-pick]");
    if (themePick) {
      const t = themePick.getAttribute("data-theme-pick");
      if (t === "base" || t === "hellenic" || t === "thelemic") setTheme(t);
      return;
    }
    const modeToggle = target.closest<HTMLElement>("[data-mode-toggle]");
    if (modeToggle) setMode(getMode() === "dark" ? "light" : "dark");
  });

  sync();
</script>
