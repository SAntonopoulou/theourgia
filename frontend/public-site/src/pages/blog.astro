---
/**
 * Blog — public blog reader (theourgia.com/blog).
 *
 * Rewritten b108-2eu: the previous version rendered six hardcoded
 * fake posts ("On the discipline of the magical record", "The
 * kingfisher and reading omens honestly", "Hekate at the crossroads
 * of three traditions" and three more) as if they were the
 * practitioner's real published essays. Visitors to production saw
 * fabricated bylines. Now client-side fetches
 * `/api/v1/blog/posts`  and shows an honest empty state when the
 * response is empty.
 *
 * Per the backend contract (`api/v1/routers/blog.py`): posts are
 * Entry rows with type=blog_post + visibility=public + no encryption.
 * The scheduler holds back rows whose `scheduled_publish_at` is in
 * the future.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicChrome from "../components/PublicChrome.astro";

const MAXW = "1180px";
---

<BaseLayout title="Blog — A public notebook, kept in Theourgia">
  <div style="background:var(--bg);color:var(--ink);font-family:var(--font-serif);min-height:100vh">

    <PublicChrome active="blog" subscribe="Subscribe" />

    <!-- header -->
    <section style="border-bottom:1px solid var(--line)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:52px clamp(16px,5vw,28px) 44px`}>
        <div style="font-family:var(--font-ui);font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:18px;display:flex;align-items:center;gap:12px">
          <span style="width:30px;height:1px;background:var(--accent)"></span>
          A public notebook · essays, notes, and quotes
        </div>
        <h1 style="font-family:var(--font-display);font-weight:700;font-size:clamp(34px,5.5vw,58px);line-height:1.05;margin:0 0 18px;max-width:18ch;letter-spacing:-.01em">Blog</h1>
        <p style="font-size:19px;line-height:1.6;color:var(--ink-soft);max-width:62ch;margin:0 0 24px">Long-form writing from the practitioner keeping this instance. Published posts appear below as they land.</p>
      </div>
    </section>

    <!-- stream -->
    <section>
      <div style={`max-width:${MAXW};margin:0 auto;padding:38px clamp(16px,5vw,28px) 70px`}>
        <div id="blog-loading" style="padding:60px 20px;text-align:center;font-family:var(--font-ui);font-size:14px;color:var(--ink-mute)">Loading…</div>

        <div id="blog-empty" style="display:none;padding:60px 20px;text-align:center;font-family:var(--font-serif);font-size:16px;color:var(--ink-mute);line-height:1.5">
          <p style="margin:0 0 12px">No public posts yet.</p>
          <p style="margin:0;font-size:14px">This blog is fresh — the practitioner keeping this instance hasn't published a post yet.</p>
        </div>

        <div id="blog-error" style="display:none;padding:60px 20px;text-align:center;font-family:var(--font-serif);font-size:15px;color:var(--warn);line-height:1.5">
          <p style="margin:0">Couldn't load posts. Try again shortly.</p>
        </div>

        <div id="blog-grid" style="display:none;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1px;background:var(--line);border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden"></div>
      </div>
    </section>

    <!-- footer -->
    <footer style="border-top:1px solid var(--line);background:var(--bg-2)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:40px clamp(16px,5vw,28px);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px`}>
        <div>
          <div style="font-family:var(--font-display);font-style:italic;font-size:17px;color:var(--ink-soft)"><span lang="el" style="font-family:var(--font-greek)">Γνῶθι σαυτόν.</span></div>
          <div style="font-family:var(--font-ui);font-size:12px;color:var(--ink-mute);margin-top:3px">A public notebook, kept in Theourgia.</div>
        </div>
        <div style="display:flex;gap:12px">
          <a href="/api/v1/blog/feed.rss" style="display:flex;align-items:center;gap:7px;padding:9px 15px;border:1px solid var(--line-2);border-radius:var(--r-md);font-family:var(--font-ui);font-size:13px;text-decoration:none;color:inherit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="6.2" cy="17.8" r="1.6" fill="currentColor" stroke="none"></circle><path d="M5 12a7 7 0 0 1 7 7M5 6a13 13 0 0 1 13 13" stroke-linecap="round"></path></svg>
            RSS
          </a>
          <a href="/api/v1/blog/feed.xml" style="display:flex;align-items:center;gap:7px;padding:9px 15px;border:1px solid var(--line-2);border-radius:var(--r-md);font-family:var(--font-ui);font-size:13px;text-decoration:none;color:inherit">Atom</a>
        </div>
      </div>
    </footer>

  </div>
</BaseLayout>

<style>
  .blog-card:hover { background: var(--bg-2) !important; }
</style>

<script is:inline>
  (async function () {
    const loading = document.getElementById("blog-loading");
    const empty = document.getElementById("blog-empty");
    const error = document.getElementById("blog-error");
    const grid = document.getElementById("blog-grid");
    if (!loading || !empty || !error || !grid) return;

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function formatDate(iso) {
      if (!iso) return "";
      try {
        return new Date(iso).toLocaleDateString(undefined, {
          day: "numeric",
          month: "short",
          year: "numeric",
        });
      } catch {
        return "";
      }
    }

    try {
      const res = await fetch("/api/v1/blog/posts");
      if (!res.ok) throw new Error("HTTP " + res.status);
      const body = await res.json();
      const posts = Array.isArray(body?.posts) ? body.posts : [];
      loading.style.display = "none";
      if (posts.length === 0) {
        empty.style.display = "block";
        return;
      }
      grid.style.display = "grid";
      grid.innerHTML = posts
        .map(function (p) {
          const title = escapeHtml(p.title || "Untitled");
          const excerpt = escapeHtml(p.excerpt || "");
          const date = formatDate(p.published_at || p.created_at);
          return (
            '<article class="blog-card" style="background:var(--bg);padding:26px 24px;display:flex;flex-direction:column;transition:background-color 0.15s ease">' +
            '<div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:12px">Essay · ' +
            date +
            "</div>" +
            '<h3 style="font-family:var(--font-display);font-size:23px;line-height:1.2;margin:0 0 10px">' +
            title +
            "</h3>" +
            (excerpt
              ? '<p style="font-size:15px;line-height:1.55;color:var(--ink-soft);margin:0 0 16px;flex:1">' +
                excerpt +
                "</p>"
              : "") +
            "</article>"
          );
        })
        .join("");
    } catch (e) {
      loading.style.display = "none";
      error.style.display = "block";
    }
  })();
</script>
