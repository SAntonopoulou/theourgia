{
  "name": "Theourgia",
  "short_name": "Theourgia",
  "description": "Magickal journal CMS and practitioner toolkit",
  "start_url": "/app/capture",
  "scope": "/app/",
  "display": "standalone",
  "orientation": "portrait",
  "theme_color": "#15120D",
  "background_color": "#15120D",
  "icons": [
    {
      "src": "/app/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/app/icon-maskable.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Quick capture",
      "short_name": "Capture",
      "description": "Write a quick entry",
      "url": "/app/capture",
      "icons": [{ "src": "/app/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Today",
      "short_name": "Today",
      "description": "Open today's vault",
      "url": "/app/",
      "icons": [{ "src": "/app/icon.svg", "sizes": "any" }]
    }
  ],
  "categories": ["lifestyle", "productivity", "books"]
}
