---
/**
 * Memorial — vault flipped to in-memoriam (digital inheritance output).
 *
 * Faithful port of ``Theourgia Memorial.dc.html``. Per
 * ``agent_onboarding.md`` § Theourgia Memorial.dc.html:
 *   · Quiet, desaturated treatment — Memorial palette overrides the base
 *     (--bg, --ink, --accent shifted; --flame is unique to this mode).
 *   · Only public content; no active interactions; preserved permanently.
 *   · Triggered by the inheritance check-in mechanic (§10.6).
 *   · Remembrances may be added — that is the one active action.
 *   · The **executor wizard** (key-share explanation, "have this
 *     conversation", check-in interval) is the missing input side — TODO.
 *
 * Demo identity name swapped from the designer's placeholder ("Sophia") to
 * "Diotima" — the vault owner's first name overlaps with the designer's
 * demo content, which would put her legal name on a public-facing
 * Memorial demo. Per the magickal-name rule, public surfaces never carry
 * her legal name. Diotima preserves the Hellenic theurgist framing.
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const MAXW = "840px";

interface PreservedWriting {
  kind: string;
  title: string;
}
interface Remembrance {
  text: string;
  attribution: string;
}

const PRESERVED: PreservedWriting[] = [
  { kind: "Essay · 2025", title: "On the discipline of the magical record" },
  { kind: "Essay · 2024", title: "Hekate at the crossroads of three traditions" },
  { kind: "Notebook · 2023", title: "A year of Liber Resh, charted" },
];

const REMEMBRANCES: Remembrance[] = [
  { text: "She taught me that doubt is a form of devotion. The lodge is dimmer without her.", attribution: "— Frater N.·.O.·." },
  { text: "Her notebooks will be read for a hundred years. Hail and farewell.", attribution: "— Aurora Lodge" },
];
---

<BaseLayout title="In memoriam — Theourgia">
  <!--
    Memorial palette is a per-surface override of the base token layer
    (per the design system: desaturation is a "mode treatment"). We apply
    it scoped to .memorial-root so the rest of the site isn't affected
    when this page is embedded as a preview. In production the palette
    will move into a [data-state="memorial"] block in shared tokens.css.
  -->
  <div class="memorial-root" style="min-height:100vh;font-family:var(--font-serif);background:var(--bg);color:var(--ink)">

    <!-- quiet header -->
    <header style="border-bottom:1px solid var(--line)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:15px 28px;display:flex;align-items:center;gap:14px`}>
        <span style="font-family:var(--font-ui);font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-mute)">In memoriam</span>
        <div style="margin-left:auto;display:flex;align-items:center;gap:12px">
          <div role="group" aria-label="Theme" class="theme-cycler" style="display:flex;gap:2px;padding:3px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2)">
            <button type="button" data-theme-pick="base" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Base</button>
            <button type="button" data-theme-pick="hellenic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Hel</button>
            <button type="button" data-theme-pick="thelemic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Thel</button>
          </div>
          <button type="button" data-mode-toggle aria-label="Toggle light and dark" class="mode-toggle" style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2);color:var(--ink-soft);cursor:pointer">
            <span data-mode-icon aria-hidden="true" style="display:inline-flex"></span>
          </button>
        </div>
      </div>
    </header>

    <!-- memorial banner -->
    <div style="border-bottom:1px solid var(--line);background:var(--bg-2)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:12px 28px;display:flex;align-items:center;gap:11px;justify-content:center;text-align:center`}>
        <span style="font-family:var(--font-ui);font-size:12.5px;color:var(--ink-soft)">This vault is preserved in memoriam. Its public writings remain; nothing new will be added.</span>
      </div>
    </div>

    <div style={`max-width:${MAXW};margin:0 auto;padding:64px 28px 80px`}>

      <!-- hero -->
      <div style="text-align:center;margin-bottom:64px">
        <svg width="34" height="46" viewBox="0 0 34 46" fill="none" style="margin-bottom:22px" aria-hidden="true">
          <path class="flame" d="M17 2c4 6 7 9 7 14a7 7 0 0 1-14 0c0-3 2-5 3-7 1 2 2 3 4 3 0-4-2-7-0-10z" fill="var(--flame)" opacity=".9"></path>
          <rect x="13" y="26" width="8" height="16" rx="1.5" fill="none" stroke="var(--accent)" stroke-width="1.2"></rect>
          <line x1="9" y1="44" x2="25" y2="44" stroke="var(--accent)" stroke-width="1.2" stroke-linecap="round"></line>
        </svg>
        <h1 style="font-family:var(--font-display);font-size:clamp(34px,5vw,50px);font-weight:700;margin:0;line-height:1.05">Diotima</h1>
        <div style="font-family:var(--font-ui);font-size:14px;letter-spacing:.06em;color:var(--ink-soft);margin:12px 0 24px">Hellenic theurgist · 1948 — 2026</div>
        <p style="font-family:var(--font-display);font-style:italic;font-size:clamp(19px,2.6vw,24px);line-height:1.5;color:var(--ink);max-width:30ch;margin:0 auto">"Keep the record the work deserves; the rest is silence."</p>
        <div lang="el" style="font-family:var(--font-greek);font-size:16px;color:var(--ink-mute);margin-top:20px">Γνῶθι σαυτόν</div>
      </div>

      <!-- preserved writings -->
      <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-mute);text-align:center;margin-bottom:24px">Selected public writings</div>
      <div style="display:flex;flex-direction:column;gap:1px;background:var(--line);border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden;margin-bottom:56px">
        {PRESERVED.map((w) => (
          <a href="/essay" class="memorial-writing" style="background:var(--bg-2);padding:20px 24px;display:block;text-decoration:none;color:inherit">
            <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:6px">{w.kind}</div>
            <div style="font-family:var(--font-display);font-size:21px;line-height:1.2">{w.title}</div>
          </a>
        ))}
      </div>

      <!-- remembrances -->
      <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-mute);text-align:center;margin-bottom:24px">Remembrances</div>
      <div style="display:flex;flex-direction:column;gap:18px;max-width:620px;margin:0 auto">
        {REMEMBRANCES.map((r) => (
          <div style="border-left:2px solid var(--line-2);padding-left:18px">
            <p style="font-family:var(--font-display);font-style:italic;font-size:17px;line-height:1.55;color:var(--ink-soft);margin:0">{r.text}</p>
            <div style="font-family:var(--font-ui);font-size:12px;color:var(--ink-mute);margin-top:8px">{r.attribution}</div>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:28px">
        <button type="button" class="leave-remembrance" style="font-family:var(--font-ui);font-size:13px;color:var(--ink-soft);padding:10px 20px;border:1px solid var(--line-2);border-radius:var(--r-md);background:transparent;cursor:pointer">Leave a remembrance</button>
      </div>

      <div style={`text-align:center;margin-top:60px;padding-top:24px;border-top:1px solid var(--line);font-family:var(--font-ui);font-size:12px;color:var(--ink-mute)`}>Preserved by her designated executor · sealed against change · Theourgia</div>

    </div>
  </div>
</BaseLayout>

<style>
  /* Memorial palette (per-surface; will move to [data-state="memorial"]
     in shared tokens once the inheritance check-in is wired). */
  .memorial-root {
    --bg: #100e0b;
    --bg-2: #16130f;
    --bg-3: #1c1813;
    --bg-sunk: #0c0a08;
    --line: rgba(225, 219, 205, .08);
    --line-2: rgba(225, 219, 205, .16);
    --ink: #d8d2c4;
    --ink-soft: #9c9484;
    --ink-mute: #6e6657;
    --accent: #9a8458;
    --accent-soft: rgba(154, 132, 88, .12);
    --flame: #c88a3e;
  }

  /* Flame flicker — quiet 3.4s, paused under reduced motion. */
  @keyframes flicker {
    0%, 100% { opacity: .85; transform: scaleY(1); }
    50%      { opacity: 1;   transform: scaleY(1.06); }
  }
  .flame {
    transform-origin: bottom center;
    animation: flicker 3.4s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .flame { animation: none; }
  }

  .memorial-writing { transition: background-color 0.15s ease; }
  .memorial-writing:hover { background: var(--bg-3) !important; }
  .leave-remembrance { transition: all 0.15s ease; }
  .leave-remembrance:hover { color: var(--ink); background: var(--bg-2); }
  .mode-toggle:hover { color: var(--ink); }

  .seg-btn[data-selected="true"] {
    color: var(--ink) !important;
    background: var(--accent-soft) !important;
    border-color: var(--line-2) !important;
  }
</style>

<script>
  // Theme + mode wiring (chrome is bespoke for Memorial — quiet header,
  // no PublicChrome, no nav).
  type Theme = "base" | "hellenic" | "thelemic";
  type Mode = "dark" | "light";

  const MOON = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z"></path></svg>`;
  const SUN = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path></svg>`;

  const getTheme = (): Theme => {
    const v = document.documentElement.getAttribute("data-theme");
    return v === "hellenic" || v === "thelemic" ? v : "base";
  };
  const getMode = (): Mode =>
    document.documentElement.getAttribute("data-mode") === "light" ? "light" : "dark";

  const sync = () => {
    const theme = getTheme();
    const mode = getMode();
    document.querySelectorAll<HTMLElement>("[data-theme-pick]").forEach((el) => {
      const matches = el.getAttribute("data-theme-pick") === theme;
      el.setAttribute("data-selected", matches ? "true" : "false");
      el.setAttribute("aria-pressed", matches ? "true" : "false");
    });
    document.querySelectorAll<HTMLElement>("[data-mode-icon]").forEach((el) => {
      el.innerHTML = mode === "dark" ? MOON : SUN;
    });
  };

  const setTheme = (theme: Theme) => {
    document.documentElement.setAttribute("data-theme", theme);
    try { localStorage.setItem("theourgia.theme", theme); } catch (_) { /* noop */ }
    sync();
  };
  const setMode = (mode: Mode) => {
    document.documentElement.setAttribute("data-mode", mode);
    try { localStorage.setItem("theourgia.mode", mode); } catch (_) { /* noop */ }
    sync();
  };

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    if (!target) return;
    const themePick = target.closest<HTMLElement>("[data-theme-pick]");
    if (themePick) {
      const t = themePick.getAttribute("data-theme-pick");
      if (t === "base" || t === "hellenic" || t === "thelemic") setTheme(t);
      return;
    }
    const modeToggle = target.closest<HTMLElement>("[data-mode-toggle]");
    if (modeToggle) setMode(getMode() === "dark" ? "light" : "dark");
  });

  sync();
</script>
