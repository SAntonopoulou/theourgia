---
/**
 * Lineage — attestation & in-browser signature verification.
 *
 * Faithful port of ``Theourgia Lineage.dc.html``. Per
 * ``agent_onboarding.md`` § Theourgia Lineage.dc.html:
 *   · Trust web — verified / self-declared / revoked states are real
 *     signature checks (§10.5). The mock here covers the 3 visually
 *     distinct states until the in-browser verification ships.
 *   · Counter-signatures link to the authority's profile (recursive
 *     trust web). Theourgia neither issues nor adjudicates degrees —
 *     it carries signatures and shows the maths.
 *
 * Demo identity swapped from the designer's placeholder ("Sophia") to
 * "Theophrastos" — same reason as Memorial. Theophrastos appears on the
 * Profile demo too, so the public site has one consistent demo persona.
 * His role tag here is adapted to the Lineage page's mixed-tradition
 * subject (the designer's demo carried a Rosy Cross degree + O.T.O.
 * membership + chaos initiation + a revoked Golden Dawn line).
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const MAXW = "920px";

type AttestationState = "verified" | "self-declared" | "revoked";
interface Attestation {
  state: AttestationState;
  kindLabel: string;
  title: string;
  authority: string;
  footerLeft: string;
  footerLeftLink?: { href: string; label: string };
  keyDigest: string;
  showVerifyButton: boolean;
  strikeTitle?: boolean;
}

const PROFILE = {
  glyph: "Θ",
  name: "Theophrastos",
  role: "Hellenic theurgist · O.T.O. initiate · chaos magician",
  blurb:
    "Twelve years in the work. The attestations below are cryptographically signed — each may be verified in your browser against the signing authority's public key.",
};

const ATTESTATIONS: Attestation[] = [
  {
    state: "verified",
    kindLabel: "Degree",
    title: "Adeptus Minor · 5°=6▢",
    authority: "Order of the Rosy Cross · conferred 2021",
    footerLeft: "Counter-signed by ",
    footerLeftLink: { href: "/profile", label: "Frater N.·.O.·." },
    keyDigest: "ed25519 · 3f9a…c21d",
    showVerifyButton: true,
  },
  {
    state: "verified",
    kindLabel: "Membership",
    title: "Aurora Lodge · O.T.O.",
    authority: "Active member in good standing · since 2019",
    footerLeft: "Counter-signed by ",
    footerLeftLink: { href: "/hub/ordo-theurgica", label: "Aurora Lodge" },
    keyDigest: "ed25519 · a17b…90fe",
    showVerifyButton: true,
  },
  {
    state: "self-declared",
    kindLabel: "Initiation",
    title: "Received from Soror V.V.V.V.V.",
    authority: "A private lineage · 2017",
    footerLeft: "Signed by Theophrastos · not yet counter-signed by an authority",
    keyDigest: "ed25519 · 7c44…1ab9",
    showVerifyButton: false,
  },
  {
    state: "revoked",
    kindLabel: "Degree",
    title: "Neophyte → Zelator",
    authority: "Hermetic Order of the Golden Dawn (a successor body)",
    footerLeft: "Revocation counter-signed by the granting body · 2024",
    keyDigest: "ed25519 · revoked",
    showVerifyButton: false,
    strikeTitle: true,
  },
];

const stateColor = (s: AttestationState): string =>
  s === "verified" ? "var(--verified)" : s === "revoked" ? "var(--revoked)" : "var(--selfdeclared)";

const stateBorder = (s: AttestationState): string =>
  s === "verified" ? "var(--verified)" : s === "revoked" ? "var(--revoked)" : "var(--line-2)";

const stateLabel = (s: AttestationState): string =>
  s === "verified" ? "Verified" : s === "revoked" ? "Revoked" : "Self-declared";
---

<BaseLayout title={`Lineage — ${PROFILE.name}`}>
  <!--
    Lineage adds three semantic tokens not in the base layer:
      --verified     = success-green ring + label
      --selfdeclared = ink-mute ring + label (no counter-sig yet)
      --revoked      = danger ring + label
    Scoped to .lineage-root so they don't leak. Will move into shared
    tokens once the trust-web read model lands.
  -->
  <div class="lineage-root" style="min-height:100vh;background:var(--bg);color:var(--ink);font-family:var(--font-serif)">

    <!-- HEADER (identity-scoped) -->
    <header style="border-bottom:1px solid var(--line);background:var(--bg)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:16px 28px;display:flex;align-items:center;gap:22px`}>
        <a href="/profile" style="display:flex;align-items:center;gap:10px;text-decoration:none;color:inherit">
          <svg width="26" height="26" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <circle cx="20" cy="20" r="17.5" stroke="var(--accent)" stroke-width="1.4"></circle>
            <line x1="9.5" y1="20" x2="30.5" y2="20" stroke="var(--accent)" stroke-width="1.4"></line>
          </svg>
          <span style="font-family:var(--font-display);font-size:19px">{PROFILE.name}</span>
        </a>
        <nav class="om-pubnav" style="display:flex;gap:20px;font-family:var(--font-ui);font-size:14px;color:var(--ink-soft)">
          <a href="/profile#writings" class="pub-nav-link" style="text-decoration:none;color:inherit">Writings</a>
          <a href="/lineage" aria-current="page" style="color:var(--ink);text-decoration:none">Lineage</a>
          <a href="/profile#about" class="pub-nav-link" style="text-decoration:none;color:inherit">About</a>
        </nav>
        <div style="margin-left:auto;display:flex;align-items:center;gap:12px">
          <div role="group" aria-label="Theme" class="om-pubseg theme-cycler" style="display:flex;gap:2px;padding:3px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2)">
            <button type="button" data-theme-pick="base" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Base</button>
            <button type="button" data-theme-pick="hellenic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Hel</button>
            <button type="button" data-theme-pick="thelemic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Thel</button>
          </div>
          <button type="button" data-mode-toggle aria-label="Toggle light and dark" class="mode-toggle" style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2);color:var(--ink-soft);cursor:pointer">
            <span data-mode-icon aria-hidden="true" style="display:inline-flex"></span>
          </button>
        </div>
      </div>
    </header>

    <div style={`max-width:${MAXW};margin:0 auto;padding:44px 28px 70px`}>

      <!-- profile -->
      <div style="display:flex;align-items:center;gap:20px;margin-bottom:14px;flex-wrap:wrap">
        <span style="width:58px;height:58px;border-radius:50%;background:var(--accent-soft);border:1px solid var(--line-2);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:24px;color:var(--accent);flex:none">{PROFILE.glyph}</span>
        <div>
          <h1 style="font-family:var(--font-display);font-size:32px;margin:0">{PROFILE.name}</h1>
          <div style="font-family:var(--font-ui);font-size:14px;color:var(--ink-soft);margin-top:3px">{PROFILE.role}</div>
        </div>
      </div>
      <p style="font-size:17px;line-height:1.6;color:var(--ink-soft);max-width:60ch;margin:0 0 38px">{PROFILE.blurb}</p>

      <div style="font-family:var(--font-ui);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:16px">Lineage &amp; attestations</div>

      <div style="display:flex;flex-direction:column;gap:14px">
        {ATTESTATIONS.map((a) => (
          <div style={`border:1px solid var(--line);border-radius:var(--r-lg);background:var(--bg-2);padding:20px 22px${a.state === "revoked" ? ";opacity:.72" : ""}`}>
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:12px">
              <div>
                <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:5px">{a.kindLabel}</div>
                <div style={`font-family:var(--font-display);font-size:21px;line-height:1.2${a.strikeTitle ? ";text-decoration:line-through;text-decoration-color:var(--revoked)" : ""}`}>{a.title}</div>
                <div style="font-family:var(--font-serif);font-size:15px;color:var(--ink-soft);margin-top:3px">{a.authority}</div>
              </div>
              <span style={`display:flex;align-items:center;gap:7px;font-family:var(--font-ui);font-size:12px;color:${stateColor(a.state)};border:1px solid ${stateBorder(a.state)};border-radius:999px;padding:5px 11px;flex:none`}>
                {a.state === "verified" ? (
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l7 3v6c0 5-3 8-7 11-4-3-7-6-7-11V5z"></path><path d="M9 12l2 2 4-4" stroke-linecap="round"></path></svg>
                ) : a.state === "revoked" ? (
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
                ) : (
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v5M12 16h.01" stroke-linecap="round"></path></svg>
                )}
                {stateLabel(a.state)}
              </span>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:13px">
              <span style={`font-family:var(--font-ui);font-size:13px;color:${a.state === "verified" ? "var(--ink-soft)" : "var(--ink-mute)"}`}>
                {a.footerLeft}{a.footerLeftLink ? (
                  <>
                    <a href={a.footerLeftLink.href} class="authority-link" style="color:var(--accent);text-decoration:none">{a.footerLeftLink.label}</a>
                    {a.state === "verified" && a.kindLabel === "Degree" ? " · Adeptus Major" : null}
                    {a.state === "verified" && a.kindLabel === "Membership" ? " · Master" : null}
                  </>
                ) : null}
              </span>
              <span style="font-family:var(--font-mono);font-size:11.5px;color:var(--ink-mute);margin-left:auto">{a.keyDigest}</span>
              {a.showVerifyButton ? (
                <button type="button" class="verify-btn" style="font-family:var(--font-ui);font-size:12.5px;color:var(--ink);padding:6px 12px;border:1px solid var(--line-2);border-radius:var(--r-sm);background:transparent;cursor:pointer">Verify signature</button>
              ) : null}
            </div>
          </div>
        ))}
      </div>

      <p style="font-family:var(--font-ui);font-size:12.5px;line-height:1.6;color:var(--ink-mute);margin:26px 0 0;max-width:62ch">Verification fetches each authority's published key and validates the signature locally. Theourgia neither issues nor adjudicates degrees — it only carries the signatures and shows you the maths.</p>

    </div>
  </div>
</BaseLayout>

<style>
  /* Lineage state-color tokens (per-surface; will move into shared tokens
     when the trust-web read model lands). */
  .lineage-root {
    --verified: #6ba892;
    --selfdeclared: #897f6b;
    --revoked: #c8554a;
  }
  [data-theme="hellenic"] .lineage-root { --verified: #5e9ba6; }
  [data-theme="thelemic"] .lineage-root { --revoked: #c5392b; }

  .pub-nav-link { transition: color 0.15s ease; }
  .pub-nav-link:hover { color: var(--ink); }
  .mode-toggle:hover { color: var(--ink); }
  .verify-btn { transition: background-color 0.15s ease; }
  .verify-btn:hover { background: var(--bg-3); }
  .authority-link { transition: opacity 0.15s ease; }
  .authority-link:hover { opacity: 0.8; }

  .seg-btn[data-selected="true"] {
    color: var(--ink) !important;
    background: var(--accent-soft) !important;
    border-color: var(--line-2) !important;
  }

  @media (max-width: 860px) { .om-pubnav { display: none !important; } }
  @media (max-width: 600px) { .om-pubseg { display: none !important; } }
</style>

<script>
  type Theme = "base" | "hellenic" | "thelemic";
  type Mode = "dark" | "light";

  const MOON = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z"></path></svg>`;
  const SUN = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path></svg>`;

  const getTheme = (): Theme => {
    const v = document.documentElement.getAttribute("data-theme");
    return v === "hellenic" || v === "thelemic" ? v : "base";
  };
  const getMode = (): Mode =>
    document.documentElement.getAttribute("data-mode") === "light" ? "light" : "dark";

  const sync = () => {
    const theme = getTheme();
    const mode = getMode();
    document.querySelectorAll<HTMLElement>("[data-theme-pick]").forEach((el) => {
      const matches = el.getAttribute("data-theme-pick") === theme;
      el.setAttribute("data-selected", matches ? "true" : "false");
      el.setAttribute("aria-pressed", matches ? "true" : "false");
    });
    document.querySelectorAll<HTMLElement>("[data-mode-icon]").forEach((el) => {
      el.innerHTML = mode === "dark" ? MOON : SUN;
    });
  };

  const setTheme = (t: Theme) => {
    document.documentElement.setAttribute("data-theme", t);
    try { localStorage.setItem("theourgia.theme", t); } catch (_) { /* noop */ }
    sync();
  };
  const setMode = (m: Mode) => {
    document.documentElement.setAttribute("data-mode", m);
    try { localStorage.setItem("theourgia.mode", m); } catch (_) { /* noop */ }
    sync();
  };

  document.addEventListener("click", (e) => {
    const t = e.target as HTMLElement | null;
    if (!t) return;
    const pick = t.closest<HTMLElement>("[data-theme-pick]");
    if (pick) {
      const v = pick.getAttribute("data-theme-pick");
      if (v === "base" || v === "hellenic" || v === "thelemic") setTheme(v);
      return;
    }
    const mode = t.closest<HTMLElement>("[data-mode-toggle]");
    if (mode) setMode(getMode() === "dark" ? "light" : "dark");
  });

  sync();

  // Verify-signature stub — real impl awaits §10.5 key fetch.
  document.querySelectorAll<HTMLButtonElement>(".verify-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const original = btn.textContent;
      btn.textContent = "Endpoint pending";
      btn.style.color = "var(--ink-mute)";
      setTimeout(() => {
        if (original) btn.textContent = original;
        btn.style.color = "var(--ink)";
      }, 2200);
    });
  });
</script>
