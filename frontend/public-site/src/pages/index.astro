              <line x1="41.11" y1="134" x2="23.79" y2="144"></line>
              <line x1="32" y1="100" x2="12" y2="100"></line>
              <line x1="41.11" y1="66" x2="23.79" y2="56"></line>
              <line x1="66" y1="41.11" x2="56" y2="23.79"></line>
            </g>
          </g>
          <g stroke="var(--accent)" fill="none">
            <circle cx="100" cy="100" r="68" stroke-width=".8" opacity=".3"></circle>
            <path d="M100 40L126.03 154.06L53.09 62.59L158.5 113.35L41.5 113.35L146.91 62.59L73.97 154.06Z" stroke-width=".9" opacity=".95" stroke-linejoin="round"></path>
