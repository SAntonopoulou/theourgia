---
/**
 * Book — per-author book sales page (Theourgia Press).
 *
 * Faithful port of ``Theourgia Book.dc.html``. The press surface — its
 * own chrome ("Theourgia Press" wordmark, Catalogue/Authors/About nav,
 * basket affordance) — distinct from the standard public chrome.
 *
 * Format selector (hardcover / paperback / digital) is interactive:
 * price + availability update inline. "Look inside" opens a themed
 * preview overlay (non-native, per the UI modals rule); a full print
 * preview links to ``/book-preview``.
 *
 * Real basket / checkout flow is out of scope here — buy button is a
 * stub until commerce ships.
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const MAXW = "1080px";

type Format = "hardcover" | "paperback" | "digital";
interface FormatOption {
  id: Format;
  label: string;
  description: string;
  price: string;
  availability: string;
}

const FORMATS: FormatOption[] = [
  { id: "hardcover", label: "Hardcover", description: "Cloth, foil, sewn · 224pp", price: "£38", availability: "In stock · ships in 2 days" },
  { id: "paperback", label: "Paperback", description: "Trade · 224pp", price: "£19", availability: "In stock · ships in 2 days" },
  { id: "digital",   label: "Digital",   description: "PDF + EPUB · DRM-free", price: "£9",  availability: "Instant download" },
];

interface ContentRow { num: string; title: string; page: string }
const CONTENTS: ContentRow[] = [
  { num: "I",   title: "The text & its witnesses",            page: "1" },
  { num: "II",  title: "The Greek, with a working English",   page: "24" },
  { num: "III", title: "The Preliminary Invocation",          page: "41" },
  { num: "IV",  title: "An order of practice",                page: "88" },
  { num: "V",   title: "Notes & sources",                     page: "151" },
];

interface SamePress { title: string; meta: string }
const SAME_PRESS: SamePress[] = [
  { title: "The Chaldean Oracles, Re-read", meta: "Forthcoming · 2027" },
  { title: "A Grammar of the Barbarous Names", meta: "£24 · in print" },
];
---

<BaseLayout title="The Bornless Working — Theourgia Press">
  <div style="min-height:100vh;background:var(--bg);color:var(--ink);font-family:var(--font-serif)">

    <!-- HEADER (Theourgia Press chrome) -->
    <header style="border-bottom:1px solid var(--line);background:var(--bg);position:sticky;top:0;z-index:20">
      <div style={`max-width:${MAXW};margin:0 auto;padding:15px 28px;display:flex;align-items:center;gap:22px`}>
        <a href="/book" style="display:flex;align-items:center;gap:11px;text-decoration:none;color:inherit">
          <svg width="26" height="26" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <circle cx="20" cy="20" r="17.5" stroke="var(--accent)" stroke-width="1.4"></circle>
            <line x1="9.5" y1="20" x2="30.5" y2="20" stroke="var(--accent)" stroke-width="1.4"></line>
          </svg>
          <span style="font-family:var(--font-display);font-size:18px;letter-spacing:.03em">Theourgia Press</span>
        </a>
        <nav class="om-pubnav" style="display:flex;gap:20px;margin-left:6px;font-family:var(--font-ui);font-size:13.5px;color:var(--ink-soft)">
          <a href="/book" class="pub-nav-link" style="text-decoration:none;color:inherit">Catalogue</a>
          <a href="/profile" class="pub-nav-link" style="text-decoration:none;color:inherit">Authors</a>
          <a href="/#manifesto" class="pub-nav-link" style="text-decoration:none;color:inherit">About</a>
        </nav>
        <div style="margin-left:auto;display:flex;align-items:center;gap:11px">
          <div role="group" aria-label="Theme" class="om-pubseg theme-cycler" style="display:flex;gap:2px;padding:3px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2)">
            <button type="button" data-theme-pick="base" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Base</button>
            <button type="button" data-theme-pick="hellenic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Hel</button>
            <button type="button" data-theme-pick="thelemic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Thel</button>
          </div>
          <button type="button" data-mode-toggle aria-label="Toggle light and dark" class="mode-toggle" style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2);color:var(--ink-soft);cursor:pointer">
            <span data-mode-icon aria-hidden="true" style="display:inline-flex"></span>
          </button>
          <button type="button" aria-label="Basket" class="basket-btn" style="display:flex;align-items:center;gap:7px;padding:7px 13px;border:1px solid var(--line-2);border-radius:var(--r-md);font-family:var(--font-ui);font-size:13px;color:var(--ink-soft);background:transparent;cursor:pointer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1 12H6zM9 8V6a3 3 0 0 1 6 0v2"></path></svg>
            <span data-basket-count>1</span>
          </button>
        </div>
      </div>
    </header>

    <!-- HERO: cover + buy -->
    <section style="border-bottom:1px solid var(--line);background:var(--bg-2)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:50px 28px;display:flex;gap:52px;align-items:flex-start;flex-wrap:wrap`}>

        <!-- COVER -->
        <div style="flex:none;width:288px;max-width:100%;margin:0 auto">
          <div style="width:288px;height:440px;background:var(--bg-3);border:1px solid var(--line-2);border-radius:3px;padding:40px 32px;display:flex;flex-direction:column;align-items:center;text-align:center;position:relative;box-shadow:0 26px 60px rgba(0,0,0,.5)">
            <div style="position:absolute;inset:13px;border:1px solid var(--accent-soft);pointer-events:none"></div>
            <div style="font-family:var(--font-ui);font-size:9.5px;letter-spacing:.24em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:26px">A Practical Edition</div>
            <svg width="58" height="58" viewBox="0 0 40 40" fill="none" style="margin-bottom:24px">
              <circle cx="20" cy="20" r="18" stroke="var(--accent)" stroke-width="1"></circle>
              <circle cx="20" cy="20" r="12.5" stroke="var(--accent)" stroke-width=".7" opacity=".6"></circle>
              <path d="M20 4.5 L23.5 16 L35 16 L25.7 23 L29.3 34.5 L20 27.5 L10.7 34.5 L14.3 23 L5 16 L16.5 16 Z" fill="none" stroke="var(--accent)" stroke-width=".8" stroke-linejoin="round" opacity=".85"></path>
            </svg>
            <h2 style="font-family:'Cinzel',serif;font-weight:600;font-size:25px;line-height:1.2;margin:0;color:var(--ink)">THE BORNLESS<br>WORKING</h2>
            <div style="width:38px;height:1px;background:var(--accent);margin:16px 0"></div>
            <div style="font-family:var(--font-display);font-style:italic;font-size:14.5px;color:var(--ink-soft)">An Invocation, Annotated</div>
            <div style="margin-top:auto;font-family:var(--font-display);font-size:15px;letter-spacing:.04em;color:var(--ink)">Theophrastos</div>
          </div>
          <button type="button" data-open-preview class="look-inside" style="display:flex;align-items:center;justify-content:center;gap:8px;width:288px;margin-top:14px;padding:9px;border:1px solid var(--line-2);border-radius:var(--r-md);font-family:var(--font-ui);font-size:13px;color:var(--ink-soft);background:transparent;cursor:pointer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12s3.5-6.5 9-6.5 9 6.5 9 6.5-3.5 6.5-9 6.5S3 12 3 12z"></path><circle cx="12" cy="12" r="2.5"></circle></svg>
            Look inside
          </button>
        </div>

        <!-- BUY -->
        <div style="flex:1 1 380px;min-width:0">
          <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);margin-bottom:13px">Theourgia Press · 2026</div>
          <h1 style="font-family:var(--font-display);font-weight:700;font-size:clamp(32px,4.4vw,44px);line-height:1.08;margin:0 0 8px;letter-spacing:-.01em">The Bornless Working</h1>
          <div style="font-family:var(--font-display);font-size:19px;color:var(--ink-soft);margin-bottom:6px">A practical edition of the Preliminary Invocation</div>
          <div style="font-family:var(--font-ui);font-size:13.5px;color:var(--ink-mute);margin-bottom:20px">by <span style="color:var(--ink)">Theophrastos</span> · foreword by the Hierophant of Ordo Theurgica</div>

          <p style="font-size:16px;line-height:1.62;color:var(--ink-soft);max-width:58ch;margin:0 0 24px">The invocation set plainly, with its history across the magical papyri, a tested order of practice, and the apparatus a serious student needs — annotated, sourced, and free of embellishment.</p>

          <!-- format selector -->
          <div style="font-family:var(--font-ui);font-size:10.5px;letter-spacing:.15em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:10px">Edition</div>
          <div style="display:flex;gap:9px;flex-wrap:wrap;margin-bottom:22px">
            {FORMATS.map((f) => (
              <button
                type="button"
                data-fmt
                data-pick={f.id}
                aria-pressed={f.id === "hardcover" ? "true" : "false"}
                class="fmt-btn"
                style="flex:1 1 150px;display:flex;flex-direction:column;gap:3px;padding:13px 15px;border:1px solid var(--line);border-radius:var(--r-md);background:var(--bg);text-align:left;cursor:pointer;color:inherit;font-family:inherit"
              >
                <span style="font-family:var(--font-display);font-size:16px;color:var(--ink)">{f.label}</span>
                <span style="font-family:var(--font-ui);font-size:11.5px;color:var(--ink-mute)">{f.description}</span>
                <span style="font-family:var(--font-mono);font-size:14px;color:var(--accent);margin-top:4px">{f.price}</span>
              </button>
            ))}
          </div>

          <!-- buy row -->
          <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <button type="button" class="buy-btn" style="display:flex;align-items:center;gap:9px;padding:13px 30px;border-radius:var(--r-md);background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-weight:700;font-size:15px;border:none;cursor:pointer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1 12H6zM9 8V6a3 3 0 0 1 6 0v2"></path></svg>
              Add to basket — <span data-buy-price>£38</span>
            </button>
            <div style="display:flex;align-items:center;gap:7px;font-family:var(--font-ui);font-size:12.5px;color:var(--success)">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.5 4.5L19 6.5"></path></svg>
              <span data-availability>In stock · ships in 2 days</span>
            </div>
          </div>
          <div style="font-family:var(--font-ui);font-size:12px;color:var(--ink-mute);margin-top:14px;display:flex;gap:18px;flex-wrap:wrap">
            <span>Ships worldwide</span><span>Signed copies on request</span><span>Digital is yours forever</span>
          </div>
        </div>
      </div>
    </section>

    <!-- BODY -->
    <section>
      <div style={`max-width:${MAXW};margin:0 auto;padding:44px 28px 72px;display:flex;gap:44px;align-items:flex-start;flex-wrap:wrap`}>

        <!-- LEFT -->
        <div style="flex:2 1 440px;min-width:0">
          <h2 style="font-family:var(--font-display);font-size:25px;margin:0 0 14px">About the book</h2>
          <p style="font-size:16px;line-height:1.7;color:var(--ink-soft);margin:0 0 14px">The Preliminary Invocation of the Goetia — the "Bornless Ritual" — is among the most-used and least-understood texts in the Western tradition. This edition returns it to its sources in the Graeco-Egyptian magical papyri, sets the Greek beside a working English, and supplies the historical and practical apparatus a serious operator wants and no more.</p>
          <p style="font-size:16px;line-height:1.7;color:var(--ink-soft);margin:0 0 32px">It is a working book, made to be opened on the altar: sewn so it lies flat, printed in a large face, and annotated at the foot of the page rather than buried in endnotes.</p>

          <h2 style="font-family:var(--font-display);font-size:25px;margin:0 0 18px">Inside</h2>
          <div style="border:1px solid var(--line);border-radius:var(--r-lg);background:var(--bg-2);overflow:hidden;margin-bottom:34px">
            {CONTENTS.map((c, i) => (
              <div style={`display:flex;align-items:baseline;gap:16px;padding:14px 20px${i < CONTENTS.length - 1 ? ";border-bottom:1px solid var(--line)" : ""}`}>
                <span style="font-family:var(--font-display);font-size:15px;color:var(--accent);width:30px;flex:none">{c.num}</span>
                <span style="font-family:var(--font-serif);font-size:16px;color:var(--ink);flex:1">{c.title}</span>
                <span style="font-family:var(--font-mono);font-size:12px;color:var(--ink-mute)">p. {c.page}</span>
              </div>
            ))}
          </div>

          <h2 style="font-family:var(--font-display);font-size:25px;margin:0 0 16px">What readers say</h2>
          <div style="display:flex;flex-direction:column;gap:16px">
            <blockquote style="margin:0;border-left:2px solid var(--accent);padding:4px 0 4px 20px">
              <p style="font-family:var(--font-display);font-style:italic;font-size:18px;line-height:1.5;color:var(--ink);margin:0 0 8px">"The first edition I would actually hand to a student. Sober, sourced, and made for the altar rather than the shelf."</p>
              <cite style="font-family:var(--font-ui);font-size:12.5px;color:var(--ink-mute);font-style:normal">— Frater Sub Rosā, O.T.O.</cite>
            </blockquote>
            <blockquote style="margin:0;border-left:2px solid var(--line-2);padding:4px 0 4px 20px">
              <p style="font-family:var(--font-display);font-style:italic;font-size:18px;line-height:1.5;color:var(--ink-soft);margin:0 0 8px">"At last the Greek and the practice in one volume, without the usual embroidery."</p>
              <cite style="font-family:var(--font-ui);font-size:12.5px;color:var(--ink-mute);font-style:normal">— The Hermetic Library Review</cite>
            </blockquote>
          </div>
        </div>

        <!-- RIGHT -->
        <aside style="flex:1 1 264px;min-width:0;display:flex;flex-direction:column;gap:18px">
          <div style="background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px">
            <div style="font-family:var(--font-ui);font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:13px">Specification</div>
            <div style="display:flex;flex-direction:column">
              {[
                ["Pages", "224"],
                ["Trim", "6 × 9 in"],
                ["Binding", "Sewn, lies flat"],
                ["Language", "Greek & English"],
                ["ISBN", "978-0-00-000000-0"],
              ].map(([label, value], i, arr) => (
                <div style={`display:flex;justify-content:space-between;padding:8px 0${i < arr.length - 1 ? ";border-bottom:1px solid var(--line)" : ""}`}>
                  <span style="font-family:var(--font-ui);font-size:12.5px;color:var(--ink-mute)">{label}</span>
                  <span style={`font-family:var(--font-${label === "ISBN" ? "mono" : "serif"});font-size:${label === "ISBN" ? "12" : "14"}px;color:var(--ink)`}>{value}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- author -->
          <div style="background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:11px">
              <span style="width:44px;height:44px;border-radius:50%;background:var(--accent-soft);border:1px solid var(--line-2);display:flex;align-items:center;justify-content:center;font-family:var(--font-glyph);color:var(--accent);font-size:20px;flex:none">Θ</span>
              <div>
                <div style="font-family:var(--font-display);font-size:17px;line-height:1.1">Theophrastos</div>
                <div style="font-family:var(--font-ui);font-size:11.5px;color:var(--ink-mute)">Theurgist · Neoplatonist</div>
              </div>
            </div>
            <p style="font-family:var(--font-serif);font-size:13.5px;line-height:1.55;color:var(--ink-soft);margin:0 0 11px">Keeps a public notebook on theurgic practice in the Hellenic current. This is his first book.</p>
            <a href="/profile" class="author-link" style="display:inline-flex;align-items:center;gap:6px;font-family:var(--font-ui);font-size:12.5px;color:var(--accent);text-decoration:none">Read his writings →</a>
          </div>

          <!-- same press -->
          <div style="background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px">
            <div style="font-family:var(--font-ui);font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:13px">From the same press</div>
            <div style="display:flex;flex-direction:column;gap:12px">
              {SAME_PRESS.map((b) => (
                <div style="display:flex;gap:11px;align-items:center">
                  <span style="width:30px;height:42px;border-radius:2px;background:var(--bg-3);border:1px solid var(--line-2);flex:none"></span>
                  <div style="min-width:0">
                    <div style="font-family:var(--font-display);font-size:14.5px;line-height:1.15">{b.title}</div>
                    <div style="font-family:var(--font-ui);font-size:11px;color:var(--ink-mute)">{b.meta}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </section>

    <footer style="border-top:1px solid var(--line);background:var(--bg-2)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:32px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px`}>
        <div style="font-family:var(--font-display);font-style:italic;font-size:16px;color:var(--ink-soft)">Theourgia Press · the record made to last.</div>
        <div style="font-family:var(--font-ui);font-size:12px;color:var(--ink-mute)">Printed on demand · carbon-measured</div>
      </div>
    </footer>

    <!-- LOOK INSIDE (themed sheet, non-native) -->
    <div id="preview-overlay" role="presentation" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.62);align-items:center;justify-content:center;padding:24px;z-index:60">
      <div role="dialog" aria-modal="true" aria-label="Look inside" style="width:min(440px,100%);background:var(--bg-2);border:1px solid var(--line-2);border-radius:var(--r-lg);box-shadow:0 28px 56px rgba(0,0,0,.6);overflow:hidden">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:15px 20px;border-bottom:1px solid var(--line)">
          <span style="font-family:var(--font-display);font-size:17px">A sample page</span>
          <button type="button" data-close-preview aria-label="Close" class="close-preview" style="width:30px;height:30px;border-radius:var(--r-sm);color:var(--ink-mute);display:flex;align-items:center;justify-content:center;background:transparent;border:none;cursor:pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"></path></svg>
          </button>
        </div>
        <div style="padding:24px;background:var(--bg-sunk)">
          <div style="background:#F2E9D4;color:#2B2114;border-radius:2px;padding:30px 28px;font-family:var(--font-display);box-shadow:0 14px 30px rgba(0,0,0,.4)">
            <div style="text-align:center;font-family:var(--font-ui);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:#8A7857;margin-bottom:14px">Chapter the Third</div>
            <p style="font-size:14px;line-height:1.62;text-align:justify;text-wrap:pretty;margin:0">
              <span style="float:left;font-family:var(--font-display);font-weight:700;font-size:46px;line-height:.72;padding:6px 8px 0 0;color:#8C2F23">T</span>hee I invoke, the Bornless one — who didst create the Earth and the Heavens; who didst create the Night and the Day. Thou art <span style="font-style:italic">Osorronophris</span>, whom no man hath seen at any time.
            </p>
          </div>
        </div>
        <div style="padding:15px 20px;border-top:1px solid var(--line);display:flex;justify-content:flex-end">
          <a href="/book-preview" class="full-preview-link" style="font-family:var(--font-ui);font-size:12.5px;color:var(--accent);text-decoration:none">Open the full print preview →</a>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  [data-fmt][aria-pressed="true"] {
    border-color: var(--accent) !important;
    background: var(--accent-soft) !important;
  }
  .fmt-btn { transition: border-color 0.15s ease; }
  .fmt-btn:hover { border-color: var(--line-2); }
  .pub-nav-link { transition: color 0.15s ease; }
  .pub-nav-link:hover { color: var(--ink); }
  .basket-btn:hover { color: var(--ink); }
  .look-inside:hover { background: var(--bg-3); color: var(--ink); }
  .buy-btn:hover { opacity: 0.9; }
  .author-link { transition: gap 0.15s ease; }
  .author-link:hover { gap: 10px !important; }
  .close-preview:hover { background: var(--bg-3); color: var(--ink); }
  .full-preview-link:hover { opacity: 0.8; }
  .mode-toggle:hover { color: var(--ink); }

  .seg-btn[data-selected="true"] {
    color: var(--ink) !important;
    background: var(--accent-soft) !important;
    border-color: var(--line-2) !important;
  }

  @media (max-width: 860px) { .om-pubnav { display: none !important; } }
  @media (max-width: 600px) { .om-pubseg { display: none !important; } }
</style>

<script is:inline define:vars={{ FORMATS }}>
  // Format selector — picks one of hardcover / paperback / digital,
  // updates the price + availability inline. Real basket flow stubbed.
  const priceNode = document.querySelector("[data-buy-price]");
  const availNode = document.querySelector("[data-availability]");

  document.querySelectorAll("[data-fmt][data-pick]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-pick");
      const fmt = FORMATS.find((f) => f.id === id);
      if (!fmt) return;
      document.querySelectorAll("[data-fmt][data-pick]").forEach((b) => {
        b.setAttribute("aria-pressed", b.getAttribute("data-pick") === id ? "true" : "false");
      });
      if (priceNode) priceNode.textContent = fmt.price;
      if (availNode) availNode.textContent = fmt.availability;
    });
  });

  // Look inside — open / close themed overlay.
  const overlay = document.getElementById("preview-overlay");
  document.querySelector("[data-open-preview]")?.addEventListener("click", () => {
    if (overlay) overlay.style.display = "flex";
  });
  const close = () => { if (overlay) overlay.style.display = "none"; };
  document.querySelectorAll("[data-close-preview]").forEach((b) => b.addEventListener("click", close));
  overlay?.addEventListener("click", (e) => { if (e.target === overlay) close(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });

  // Theme / mode wiring.
  const MOON = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z"></path></svg>`;
  const SUN = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path></svg>`;
  const getTheme = () => {
    const v = document.documentElement.getAttribute("data-theme");
    return v === "hellenic" || v === "thelemic" ? v : "base";
  };
  const getMode = () =>
    document.documentElement.getAttribute("data-mode") === "light" ? "light" : "dark";
  const sync = () => {
    const theme = getTheme();
    const mode = getMode();
    document.querySelectorAll("[data-theme-pick]").forEach((el) => {
      const matches = el.getAttribute("data-theme-pick") === theme;
      el.setAttribute("data-selected", matches ? "true" : "false");
      el.setAttribute("aria-pressed", matches ? "true" : "false");
    });
    document.querySelectorAll("[data-mode-icon]").forEach((el) => {
      el.innerHTML = mode === "dark" ? MOON : SUN;
    });
  };
  document.addEventListener("click", (e) => {
    const t = e.target;
    if (!t) return;
    const pick = t.closest("[data-theme-pick]");
    if (pick) {
      const v = pick.getAttribute("data-theme-pick");
      if (v === "base" || v === "hellenic" || v === "thelemic") {
        document.documentElement.setAttribute("data-theme", v);
        try { localStorage.setItem("theourgia.theme", v); } catch (_) {}
        sync();
      }
      return;
    }
    const mode = t.closest("[data-mode-toggle]");
    if (mode) {
      const next = getMode() === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-mode", next);
      try { localStorage.setItem("theourgia.mode", next); } catch (_) {}
      sync();
    }
  });
  sync();
</script>
