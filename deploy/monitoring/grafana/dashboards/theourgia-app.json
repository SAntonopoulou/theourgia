    {
      "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" },
      "description": "Backup attempts per hour by outcome (theourgia_backup_runs_total). The beat schedule runs a full backup daily at 03:15 UTC and incrementals every 6 hours.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
