---
/**
 * Landing — theourgia.com homepage.
 *
 * Faithful port of ``Theourgia Landing.dc.html``. Per
 * ``agent_onboarding.md`` § Landing:
 *   · Route ``/`` · public chrome · page-scroll · no app shell.
 *   · Theme/mode switcher is a genuine preview affordance for visitors
 *     (the one surface where this is user-facing).
 *   · Marketing copy is static for now; the "latest from blog" teaser +
 *     version/install links wire to real ② feeds when the blog publishes
 *     and the release pipeline ships.
 *   · Newsletter capture must be real (validation, humane errors) — the
 *     write target is stubbed locally until the newsletter endpoint
 *     lands.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicChrome from "../components/PublicChrome.astro";

const MAXW = "1180px";

const LANDING_NAV = [
  { href: "#manifesto", label: "Manifesto" },
  { href: "#tongues", label: "Typography" },
  { href: "#toolkit", label: "Toolkit" },
  { href: "#traditions", label: "Traditions" },
  { href: "#sovereign", label: "Self-host" },
];
---

<BaseLayout title="Theourgia — Keep the record the work deserves.">
  <div style={`background:var(--bg);color:var(--ink);font-family:var(--font-serif);min-height:100vh;overflow-x:hidden`}>

    <PublicChrome nav={LANDING_NAV} />


    <!-- HERO -->
    <section id="top" style={`max-width:${MAXW};margin:0 auto;padding:clamp(56px,8vw,104px) clamp(16px,5vw,28px) clamp(40px,5vw,72px);display:grid;grid-template-columns:1.15fr .85fr;gap:48px;align-items:center`}>
      <div>
        <div style="display:flex;align-items:center;gap:14px;margin-bottom:26px">
          <span style="width:40px;height:1px;background:var(--accent);opacity:.7"></span>
          <span style="font-family:var(--font-ui);font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-mute)">A journal for the Great Work</span>
        </div>
        <h1 style="font-family:var(--font-display);font-weight:700;font-size:clamp(44px,6vw,76px);line-height:1.02;letter-spacing:-.01em;margin:0 0 8px;color:var(--ink)">Keep the record<br>the work deserves.</h1>
        <p style="font-family:var(--font-serif);font-style:italic;font-size:clamp(19px,2.2vw,24px);color:var(--accent);margin:0 0 24px"><span lang="el" style="font-family:var(--font-greek)">θεουργία</span> — the working of divine things.</p>
        <p style="font-size:18px;line-height:1.62;color:var(--ink-soft);max-width:50ch;margin:0 0 32px">A magickal journal and full practitioner's toolkit — open source, self-hostable, federated. Built with the seriousness of a primary source and the rigour of scientific illuminism, for Thelemites, theurgists, witches, Hermeticists, and chaotes alike.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;align-items:center;margin-bottom:26px">
          <a href="#sovereign" class="pub-cta-primary" style="padding:13px 26px;border-radius:9px;background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-weight:700;font-size:15px;letter-spacing:.01em;text-decoration:none">Begin the work →</a>
          <a href="#manifesto" class="pub-cta-secondary" style="padding:13px 22px;border-radius:9px;border:1px solid var(--line-2);color:var(--ink);font-family:var(--font-ui);font-size:15px;text-decoration:none">Read the manifesto</a>
        </div>
        <div style="display:flex;gap:18px;flex-wrap:wrap;font-family:var(--font-ui);font-size:12.5px;letter-spacing:.04em;color:var(--ink-mute)">
          <span>v0.1 · AGPL-3.0</span><span style="opacity:.4">·</span><span>No telemetry</span><span style="opacity:.4">·</span><span>Your keys, your server</span>
        </div>
      </div>
      <div style="display:flex;justify-content:center;align-items:center">
        <svg viewBox="0 0 200 200" width="100%" style="max-width:380px;aspect-ratio:1" role="img" aria-label="Astrolabe with seven-pointed star">
          <title>Astrolabe with seven-pointed star</title>
