      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" }, "editorMode": "code", "expr": "sum by (path_template) (rate(theourgia_http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "{{path_template}}", "refId": "A" }
