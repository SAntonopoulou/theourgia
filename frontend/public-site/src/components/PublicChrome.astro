---
/**
 * PublicChrome — shared header for public-site surfaces.
 *
 * Per ``agent_onboarding.md`` § 3.1 "Public site chrome": one public
 * layout used by Landing, Blog, Essay, Newsletter, Profile, Hub, Book,
 * Docs, Style Guide. Themeable. The theme cycler + mode toggle live here
 * (the Landing surface treats this as a genuine preview affordance per
 * the design).
 */

interface NavItem {
  href: string;
  label: string;
}

interface Props {
  /** Which nav item is the current page (visual highlight). */
  active?: string;
  /** Custom nav items; defaults to the Landing anchor menu. */
  nav?: NavItem[];
  /**
   * If set, render a primary CTA button on the right (e.g. "Subscribe"
   * on Blog, "Begin" on Landing). String becomes the button label;
   * href defaults to ``#subscribe``.
   */
  subscribe?: string;
  subscribeHref?: string;
  /** Override the max-width of the chrome wrapper. */
  maxWidth?: string;
}

const {
  active,
  nav = [
    { href: "/#manifesto", label: "Manifesto" },
    { href: "/#tongues", label: "Typography" },
    { href: "/#toolkit", label: "Toolkit" },
    { href: "/blog", label: "Blog" },
    { href: "/#sovereign", label: "Self-host" },
  ],
  subscribe,
  subscribeHref = "#subscribe",
  maxWidth = "1180px",
} = Astro.props;
---

<a href="#om-main" class="om-skip-link" style="position:absolute;left:8px;top:8px;padding:8px 16px;background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-size:13px;font-weight:700;border-radius:var(--r-md, 6px);z-index:1000;text-decoration:none;transform:translateY(-200%);transition:transform 120ms ease" onfocus="this.style.transform='translateY(0)'" onblur="this.style.transform='translateY(-200%)'">Skip to main content</a>
<header style="position:sticky;top:0;z-index:50;background:var(--bg);border-bottom:1px solid var(--line)">
  <div class="om-pubwrap" style={`max-width:${maxWidth};margin:0 auto;padding:14px clamp(16px,5vw,28px);display:flex;align-items:center;gap:28px`}>
    <a href="/" style="display:flex;align-items:center;gap:12px;flex:none;text-decoration:none;color:inherit">
      <svg width="34" height="34" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <circle cx="20" cy="20" r="17.5" stroke="var(--accent)" stroke-width="1.4"></circle>
        <circle cx="20" cy="20" r="12" stroke="var(--accent)" stroke-width="1" opacity=".55"></circle>
        <line x1="9.5" y1="20" x2="30.5" y2="20" stroke="var(--accent)" stroke-width="1.4"></line>
      </svg>
      <span style="font-family:var(--font-display);font-size:23px;letter-spacing:.04em;color:var(--ink)">Theourgia</span>
    </a>
    <nav class="om-pubnav" style="display:flex;gap:26px;margin-left:8px;font-family:var(--font-ui);font-size:14.5px;color:var(--ink-soft)">
      {nav.map((item) => (
        <a
          href={item.href}
          class="pub-nav-link"
          aria-current={active && item.label.toLowerCase() === active.toLowerCase() ? "page" : undefined}
          style={`text-decoration:none;color:${active && item.label.toLowerCase() === active.toLowerCase() ? "var(--ink)" : "inherit"}`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div style="margin-left:auto;display:flex;align-items:center;gap:10px">
      <div role="group" aria-label="Theme" class="om-pubseg theme-cycler" style="display:flex;gap:2px;padding:3px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2)">
        <button type="button" data-theme-pick="base" class="seg-btn" style="padding:6px 13px;font-family:var(--font-ui);font-size:12.5px;letter-spacing:.04em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Base</button>
        <button type="button" data-theme-pick="hellenic" class="seg-btn" style="padding:6px 13px;font-family:var(--font-ui);font-size:12.5px;letter-spacing:.04em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Hellenic</button>
        <button type="button" data-theme-pick="thelemic" class="seg-btn" style="padding:6px 13px;font-family:var(--font-ui);font-size:12.5px;letter-spacing:.04em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Thelemic</button>
      </div>
      <button type="button" data-mode-toggle aria-label="Toggle light and dark" title="Toggle mode" style="display:flex;align-items:center;gap:7px;padding:7px 11px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2);font-family:var(--font-ui);font-size:12.5px;color:var(--ink-soft);cursor:pointer">
        <span data-mode-icon aria-hidden="true" style="display:inline-flex"></span><span data-mode-label>Dark</span>
      </button>
      {subscribe ? (
        <a href={subscribeHref} class="pub-cta-primary" style="padding:8px 15px;border-radius:var(--r-md);background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-weight:700;font-size:13px;text-decoration:none">{subscribe}</a>
      ) : (
        <a href="/app/signin" class="pub-cta-primary" style="padding:8px 18px;border-radius:var(--r-md);background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-weight:700;font-size:13px;text-decoration:none">Sign in</a>
      )}
    </div>
  </div>
</header>

<style>
  .pub-nav-link { transition: color 0.15s ease; }
  .pub-nav-link:hover { color: var(--ink); }
  .pub-cta-primary:hover { opacity: 0.9; }
  .seg-btn[data-selected="true"] {
    color: var(--ink) !important;
    background: var(--accent-soft) !important;
    border-color: var(--line-2) !important;
  }
  @media (max-width: 860px) { .om-pubnav { display: none !important; } }
  @media (max-width: 600px) { .om-pubseg { display: none !important; } }
</style>

<script>
  // Theme + mode persistence — used by every public surface that includes
  // PublicChrome. Avoid duplicating this script per page; rely on
  // window.__theourgiaChromeWired so multiple imports stay idempotent.
  type Theme = "base" | "hellenic" | "thelemic";
  type Mode = "dark" | "light";

  declare global {
    interface Window { __theourgiaChromeWired?: boolean }
  }

  if (!window.__theourgiaChromeWired) {
    window.__theourgiaChromeWired = true;

    const MOON_PATH = "M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z";
    const SUN_GROUP = `<circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path>`;

    const getTheme = (): Theme => {
      const v = document.documentElement.getAttribute("data-theme");
      return v === "hellenic" || v === "thelemic" ? v : "base";
    };
    const getMode = (): Mode =>
      document.documentElement.getAttribute("data-mode") === "light" ? "light" : "dark";

    const setTheme = (theme: Theme) => {
      document.documentElement.setAttribute("data-theme", theme);
      try { localStorage.setItem("theourgia.theme", theme); } catch (_) { /* noop */ }
      sync();
    };
    const setMode = (mode: Mode) => {
      document.documentElement.setAttribute("data-mode", mode);
      try { localStorage.setItem("theourgia.mode", mode); } catch (_) { /* noop */ }
      sync();
    };

    const svgFor = (mode: Mode) =>
      mode === "dark"
        ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="${MOON_PATH}"></path></svg>`
        : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${SUN_GROUP}</svg>`;

    const sync = () => {
      const theme = getTheme();
      const mode = getMode();
      document.querySelectorAll<HTMLElement>("[data-theme-pick]").forEach((el) => {
        const matches = el.getAttribute("data-theme-pick") === theme;
        el.setAttribute("data-selected", matches ? "true" : "false");
        el.setAttribute("aria-pressed", matches ? "true" : "false");
      });
      document.querySelectorAll<HTMLElement>("[data-mode-icon]").forEach((el) => {
        el.innerHTML = svgFor(mode);
      });
      document.querySelectorAll<HTMLElement>("[data-mode-label]").forEach((el) => {
        el.textContent = mode === "dark" ? "Dark" : "Light";
      });
    };

    document.addEventListener("click", (event) => {
      const target = event.target as HTMLElement | null;
      if (!target) return;
      const themePick = target.closest<HTMLElement>("[data-theme-pick]");
      if (themePick) {
        const t = themePick.getAttribute("data-theme-pick") as Theme | null;
        if (t === "base" || t === "hellenic" || t === "thelemic") setTheme(t);
        return;
      }
      const modeToggle = target.closest<HTMLElement>("[data-mode-toggle]");
      if (modeToggle) setMode(getMode() === "dark" ? "light" : "dark");
    });

    sync();
  }
</script>
