              <line x1="45.36" y1="165.11" x2="43.43" y2="167.41"></line>
              <line x1="39.9" y1="160.1" x2="37.77" y2="162.23"></line>
              <line x1="34.89" y1="154.64" x2="32.59" y2="156.57"></line>
              <line x1="30.37" y1="148.75" x2="27.91" y2="150.47"></line>
              <line x1="28.99" y1="141" x2="23.79" y2="144" stroke-width="1"></line>
              <line x1="22.96" y1="135.92" x2="20.24" y2="137.19"></line>
              <line x1="20.13" y1="129.07" x2="17.31" y2="130.1"></line>
              <line x1="17.9" y1="122" x2="15" y2="122.78"></line>
              <line x1="16.29" y1="114.76" x2="13.34" y2="115.28"></line>
              <line x1="15.32" y1="107.41" x2="12.33" y2="107.67"></line>
              <line x1="18" y1="100" x2="12" y2="100" stroke-width="1"></line>
              <line x1="15.32" y1="92.59" x2="12.33" y2="92.33"></line>
              <line x1="16.29" y1="85.24" x2="13.34" y2="84.72"></line>
              <line x1="17.9" y1="78" x2="15" y2="77.22"></line>
              <line x1="20.13" y1="70.93" x2="17.31" y2="69.9"></line>
              <line x1="22.96" y1="64.08" x2="20.24" y2="62.81"></line>
              <line x1="28.99" y1="59" x2="23.79" y2="56" stroke-width="1"></line>
              <line x1="30.37" y1="51.25" x2="27.91" y2="49.53"></line>
              <line x1="34.89" y1="45.36" x2="32.59" y2="43.43"></line>
              <line x1="39.9" y1="39.9" x2="37.77" y2="37.77"></line>
              <line x1="45.36" y1="34.89" x2="43.43" y2="32.59"></line>
              <line x1="51.25" y1="30.37" x2="49.53" y2="27.91"></line>
              <line x1="59" y1="28.99" x2="56" y2="23.79" stroke-width="1"></line>
              <line x1="64.08" y1="22.96" x2="62.81" y2="20.24"></line>
              <line x1="70.93" y1="20.13" x2="69.9" y2="17.31"></line>
              <line x1="78" y1="17.9" x2="77.22" y2="15"></line>
              <line x1="85.24" y1="16.29" x2="84.72" y2="13.34"></line>
              <line x1="92.59" y1="15.32" x2="92.33" y2="12.33"></line>
            </g>
            <g stroke-width=".8" opacity=".5">
              <line x1="100" y1="32" x2="100" y2="12"></line>
              <line x1="134" y1="41.11" x2="144" y2="23.79"></line>
              <line x1="158.89" y1="66" x2="176.21" y2="56"></line>
              <line x1="168" y1="100" x2="188" y2="100"></line>
