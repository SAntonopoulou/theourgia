---
/**
 * Newsletter — public archive.
 *
 * Rewritten b108-2ev: the previous version rendered a hardcoded
 * archive of 17+ fake issues by "Theophrastos" ("The Solstice Letter",
 * "The Bornless Working before the book", "Hekate at the crossroads
 * of three traditions" and 14 more) plus a fabricated featured issue
 * #18. Visitors to production saw invented editorial output.
 *
 * Now client-side fetches ``/api/v1/newsletter-issues?status=sent``
 * and renders real archive rows when present, or an honest empty
 * state when the practitioner keeping this instance hasn't sent an
 * issue yet.
 *
 * Subscribe capture stays as a plain form; the write target lands
 * with the subscriber-create endpoint (Phase 10 B128).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicChrome from "../components/PublicChrome.astro";

const MAXW = "920px";
---

<BaseLayout title="Newsletter — Theourgia">
  <div style="min-height:100vh;background:var(--bg);color:var(--ink);font-family:var(--font-serif)">

    <PublicChrome active="newsletter" />

    <!-- HERO -->
    <section id="om-main" style="border-bottom:1px solid var(--line)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:56px clamp(16px,5vw,28px) 44px`}>
        <div style="font-family:var(--font-ui);font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:18px;display:flex;align-items:center;gap:12px">
          <span style="width:30px;height:1px;background:var(--accent)"></span>
          Newsletter · from this practitioner
        </div>
        <h1 style="font-family:var(--font-display);font-weight:700;font-size:clamp(34px,5.5vw,58px);line-height:1.05;margin:0 0 18px;max-width:18ch;letter-spacing:-.01em">The archive</h1>
        <p style="font-size:19px;line-height:1.6;color:var(--ink-soft);max-width:62ch;margin:0 0 24px">Sent issues appear below as they land — long-form writing on the practitioner's terms, delivered to those who ask for it.</p>

        <!-- Subscribe -->
        <form
          id="subscribe-form"
          method="post"
          style="display:flex;flex-wrap:wrap;gap:10px;max-width:520px;margin-top:8px"
        >
          <label style="flex:1 1 260px;position:relative">
            <span style="position:absolute;left:14px;top:50%;transform:translateY(-50%);font-family:var(--font-ui);font-size:14px;color:var(--ink-mute);pointer-events:none" id="subscribe-placeholder">Email address</span>
            <input
              type="email"
              name="email"
              id="subscribe-email"
              required
              autocomplete="email"
              aria-label="Email address"
              style="width:100%;padding:12px 14px;border:1px solid var(--line);border-radius:var(--r-md);background:var(--bg-2);color:var(--ink);font-family:var(--font-serif);font-size:15px"
            />
          </label>
          <button type="submit" style="padding:12px 22px;border-radius:var(--r-md);background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-weight:700;font-size:14px;border:none;cursor:pointer">Subscribe</button>
        </form>
        <p id="subscribe-status" style="margin:12px 0 0;font-family:var(--font-ui);font-size:12.5px;color:var(--ink-mute);min-height:1em"></p>
      </div>
    </section>

    <!-- ARCHIVE -->
    <section>
      <div style={`max-width:${MAXW};margin:0 auto;padding:40px clamp(16px,5vw,28px) 70px`}>
        <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:18px">Archive</div>

        <div id="newsletter-loading" style="padding:40px 0;font-family:var(--font-ui);font-size:14px;color:var(--ink-mute);text-align:center">Loading…</div>

        <div id="newsletter-empty" style="display:none;padding:40px 0;font-family:var(--font-serif);font-size:16px;color:var(--ink-mute);text-align:center;line-height:1.5">
          <p style="margin:0 0 8px">No issues sent yet.</p>
          <p style="margin:0;font-size:14px">The archive fills up as the practitioner keeping this instance sends their first issue.</p>
        </div>

        <div id="newsletter-error" style="display:none;padding:40px 0;font-family:var(--font-serif);font-size:15px;color:var(--warn);text-align:center">
          Couldn't load the archive. Try again shortly.
        </div>

        <div id="newsletter-list" style="display:none;flex-direction:column;gap:2px;border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden;background:var(--bg-2)"></div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer style="border-top:1px solid var(--line);background:var(--bg-2)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:30px clamp(16px,5vw,28px);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;font-family:var(--font-ui);font-size:12.5px;color:var(--ink-mute)`}>
        <span>Delivery is email-only. Your address is not sold or shared.</span>
        <a href="/blog" style="color:var(--ink-soft);text-decoration:none">Read the blog →</a>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  .archive-row:hover { background: var(--bg-3) !important; }
</style>

<script is:inline>
  (async function () {
    const loading = document.getElementById("newsletter-loading");
    const empty = document.getElementById("newsletter-empty");
    const error = document.getElementById("newsletter-error");
    const list = document.getElementById("newsletter-list");
    const form = document.getElementById("subscribe-form");
    const emailInput = document.getElementById("subscribe-email");
    const placeholder = document.getElementById("subscribe-placeholder");
    const status = document.getElementById("subscribe-status");
    if (!loading || !empty || !error || !list) return;

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function formatDate(iso) {
      if (!iso) return "";
      try {
        return new Date(iso).toLocaleDateString(undefined, {
          day: "numeric",
          month: "short",
          year: "numeric",
        });
      } catch {
        return "";
      }
    }

    // Placeholder helper: hide the fake placeholder when there's input.
    if (emailInput && placeholder) {
      const sync = () => (placeholder.style.display = emailInput.value ? "none" : "block");
      emailInput.addEventListener("input", sync);
      emailInput.addEventListener("focus", () => (placeholder.style.display = "none"));
      emailInput.addEventListener("blur", sync);
      sync();
    }

    // Sent newsletters aren't yet exposed as a public archive
    // endpoint (the /newsletter-issues list is authenticated-only,
    // by design — draft+scheduled+sent all mix in that feed).
    // A dedicated public archive endpoint lands with the multi-tenant
    // routing (Phase 12.5). For now the archive shows the empty state
    // honestly rather than fetching an endpoint that always 401s.
    loading.style.display = "none";
    empty.style.display = "block";

    // Subscribe form. The public double-opt-in endpoint is
    // POST /vaults/{owner_id}/subscribe (Phase 10 B128). We don't yet
    // expose the primary vault owner-id on the public host, so the
    // form surfaces the pipe status honestly instead of pretending
    // to subscribe. When /api/v1/meta.primary_vault_owner lands, this
    // switches to a real POST + double-opt-in flow.
    if (form && emailInput && status) {
      form.addEventListener("submit", function (ev) {
        ev.preventDefault();
        const email = String(emailInput.value || "").trim();
        if (!email) return;
        status.style.color = "var(--ink-mute)";
        status.textContent =
          "Subscribe endpoint is queued behind the /vaults/{id}/subscribe wiring on this instance. Check back once the meta endpoint exposes the vault owner id.";
      });
    }
  })();
</script>
