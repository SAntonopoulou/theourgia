{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@theourgia/public-site",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "description": "Theourgia public-facing Astro site (landing, blogs, books, RSS)",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 4321",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1 --port 4321",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@theourgia/shared": "workspace:*",
    "astro": "^6.4.0",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
