# Theourgia — environment variable template
#
# Copy to .env (or .env.local / .env.production) and fill in.
# Never commit any .env.* file other than this template — see .gitignore.
#
# All variables are namespaced THEOURGIA_* unless they are widely-recognized
# environment variables (DATABASE_URL, REDIS_URL, PORT, etc.).

# =============================================================================
# Application
# =============================================================================

# Environment name: development | production | test
THEOURGIA_ENV=development

# Secret used for signing session tokens and other internal cryptography.
# Generate with: openssl rand -base64 64
# REQUIRED. Application refuses to start if unset in non-test environments.
THEOURGIA_SECRET_KEY=

# Public base URL (no trailing slash). Used for absolute links in newsletters,
# RSS feeds, federation actor IDs, etc.
THEOURGIA_BASE_URL=https://theourgia.com

# Instance identifier. Used in federation. Typically the host part of BASE_URL.
THEOURGIA_INSTANCE_ID=theourgia.com

# Log level: debug | info | warning | error
THEOURGIA_LOG_LEVEL=info

# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection. Only PostgreSQL is supported (see ADR-0005).
DATABASE_URL=postgresql+asyncpg://theourgia:theourgia@localhost:5432/theourgia

# Migration database role (DDL privileges); typically the same as DATABASE_URL
# in development. Documented separately because production should use a
# dedicated migration role.
THEOURGIA_MIGRATION_DATABASE_URL=

# =============================================================================
# Redis (sessions, cache, queue)
# =============================================================================

REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Encryption
# =============================================================================

# Server-side encryption master key. Per-vault data keys are wrapped by this.
# Generate with: openssl rand -base64 64
# REQUIRED for Mode A (server-side at rest) encryption.
THEOURGIA_MASTER_ENCRYPTION_KEY=

# =============================================================================
# Astrology / Swiss Ephemeris
# =============================================================================

# Path to Swiss Ephemeris data files (.se1). Defaults to bundled location.
THEOURGIA_EPHE_PATH=backend/data/ephe

# =============================================================================
# Federation
# =============================================================================

# Per-instance Ed25519 keypair for federation message signing.
# Auto-generated at first start if these paths exist as empty/missing.
THEOURGIA_FEDERATION_PRIVATE_KEY_PATH=/var/lib/theourgia/federation.key
THEOURGIA_FEDERATION_PUBLIC_KEY_PATH=/var/lib/theourgia/federation.pub

# =============================================================================
# Stripe (Phase 10; leave blank in early development)
# =============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# Email (Phase 10; leave blank in early development)
# =============================================================================

# Either configure SMTP directly or a managed provider.
# Backend selection: smtp | postmark | resend | ses | mailgun | none
THEOURGIA_EMAIL_BACKEND=none

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

POSTMARK_TOKEN=
RESEND_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# =============================================================================
# Backups (Restic to S3-compatible / R2)
# =============================================================================

# Required for Phase 01 backup tooling to run.
RESTIC_REPOSITORY=
RESTIC_PASSWORD=

# For S3-compatible backends (Cloudflare R2, Hetzner Object Storage, Backblaze B2):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto

# =============================================================================
# AI agent integration (Phase 16; opt-in)
# =============================================================================

# If unset, the agent daemon is not started. Users supply their own keys.
# This is the operator-level default; production magicians provide their
# own keys via the C5 BYO Key Settings surface, encrypted Mode B.
ANTHROPIC_API_KEY=

# Per-vault cost cap defaults (USD); user-configurable per agent
THEOURGIA_AGENT_DEFAULT_COST_CAP_DAILY=2.00
THEOURGIA_AGENT_DEFAULT_COST_CAP_MONTHLY=30.00

# ── Daemon ↔ vault bridge ────────────────────────────────────────────────────
# URL the backend uses to reach the daemon. With docker-compose, the daemon
# is reachable as `agent-daemon:8002` on the internal network. Unset disables
# the H10 C-cluster routes (they return 503).
THEOURGIA_AGENT_DAEMON_URL=http://agent-daemon:8002

# Shared secret presented as `X-Daemon-Auth` on every backend → daemon call.
# Must match the daemon's THEOURGIA_AGENT_CONTROL_TOKEN. Generate with:
#   openssl rand -base64 48
THEOURGIA_AGENT_DAEMON_CONTROL_TOKEN=

# ── Daemon own configuration ─────────────────────────────────────────────────
# Daemon's own DB (separate from backend DB — daemon failures cannot
# poison the vault).
THEOURGIA_AGENT_DB_USER=theourgia
THEOURGIA_AGENT_DB_PASSWORD=
THEOURGIA_AGENT_DB_NAME=theourgia_agent

# Listen on all interfaces in-container (Docker network isolation is the
# enforcement boundary; the daemon is never exposed outside the network).
THEOURGIA_AGENT_LISTEN_HOST=0.0.0.0
THEOURGIA_AGENT_LISTEN_PORT=8002

# Same value as THEOURGIA_AGENT_DAEMON_CONTROL_TOKEN above — the
# variable is read by the daemon under its own name.
THEOURGIA_AGENT_CONTROL_TOKEN=

# HKDF salt for Mode B key derivation. Generate once + keep stable:
#   openssl rand -hex 32
# Rotating this requires re-encrypting every stored agent API key.
THEOURGIA_AGENT_HKDF_SALT=

# =============================================================================
# Plugin registry (Phase 14 / H10 Cluster A)
# =============================================================================

# Base URL of the registry service. With docker-compose, reachable as
# `registry:8003` on the internal network.
THEOURGIA_REGISTRY_URL=http://registry:8003

# Registry's own DB.
THEOURGIA_REGISTRY_DB_USER=theourgia
THEOURGIA_REGISTRY_DB_PASSWORD=
THEOURGIA_REGISTRY_DB_NAME=theourgia_registry

# Bootstrap DID for the first maintainer (LEAD). This is the only way
# to seed the maintainer table — once set, the first authenticated
# request from this DID creates the LEAD row.
THEOURGIA_REGISTRY_BOOTSTRAP_MAINTAINER_DID=

# Host-bound port for the registry container (plugins.theourgia.com).
# Pick from your reserved local port range. Defaults to 8193.
THEOURGIA_REGISTRY_HOST_PORT=8193

# =============================================================================
# Telemetry — there is none
# =============================================================================

# This section is intentionally empty.
# Theourgia ships ZERO telemetry. There is no opt-in. No usage data is
# transmitted anywhere. A CI test verifies this on every build.
