---
/**
 * Print — Ritual Sheet (parchment, A4 portrait).
 *
 * Faithful port of ``Theourgia Print - Ritual Sheet.dc.html``. Per
 * ``agent_onboarding.md`` § Theourgia Print - Ritual Sheet:
 *   · Parchment ritual sheet with pentagram diagram; print-grade.
 *   · Shared **print sheet frame** primitive — fixed page size,
 *     parchment surface for screen preview, `@media print` strips chrome
 *     and the parchment background so output is clean and ink-economical.
 *   · True print CSS — @page size/margins, ink-light treatment.
 *   · Used for **real ritual use** — legibility and correct script
 *     rendering matter.
 *
 * Demo identity is "Theophrastos · Adeptus Minor" (consistent with the
 * Profile / Lineage demos). Designer's placeholder was "Sophia" — same
 * magickal-name reason as the other surfaces.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ritual sheet — Theourgia</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cardo:ital,wght@0,400;0,700;1,400&family=Inria+Sans:wght@300;400;700&family=JetBrains+Mono:wght@400&family=Frank+Ruhl+Libre:wght@500&family=Noto+Sans+Symbols&display=swap"
    />
    <style>
      :root {
        --font-display: "Cardo", serif;
        --font-ui: "Inria Sans", sans-serif;
        --font-mono: "JetBrains Mono", monospace;
        --font-hebrew: "Frank Ruhl Libre", serif;
        --font-glyph: "Noto Sans Symbols", "Cardo", serif;
        --paper: #f2e9d4;
        --paper-edge: #e7dbbf;
        --ink: #2b2114;
        --ink-soft: #5b4b33;
        --ink-mute: #8a7857;
        --rule: #c9b68c;
        --seal: #8c2f23;
      }
      * { box-sizing: border-box; }
      body { margin: 0; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
      button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
      :focus-visible { outline: 2px solid #c7a24c; outline-offset: 2px; }

      .scroll::-webkit-scrollbar { width: 10px; }
      .scroll::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, .18);
        border-radius: 10px;
        border: 3px solid transparent;
        background-clip: content-box;
      }

      /* Real print CSS — strip chrome, drop parchment surface, set @page. */
      @page { size: A4 portrait; margin: 0; }
      @media print {
        .chrome { display: none !important; }
        .surround {
          background: #fff !important;
          padding: 0 !important;
          overflow: visible !important;
        }
        .sheet {
          box-shadow: none !important;
          margin: 0 !important;
          width: 100% !important;
          min-height: auto !important;
          background: #fff !important;
        }
        body { background: #fff !important; }
      }

      /* Screen preview scales down on narrow viewports. */
      @media screen and (max-width: 820px) {
        .sheet {
          width: 100% !important;
          max-width: 760px;
          min-height: 0 !important;
          padding: 44px 30px !important;
        }
      }

      .print-btn:hover { opacity: .9; }
    </style>
  </head>
  <body>
    <div style="height:100vh;display:flex;flex-direction:column;background:#17140F;overflow:hidden;font-family:var(--font-ui)">

      <!-- PRINT CHROME -->
      <div class="chrome" style="display:flex;align-items:center;gap:18px;padding:12px 24px;border-bottom:1px solid rgba(236,229,214,.12);background:#15120D;color:#ECE5D6;flex-wrap:wrap">
        <div style="font-family:var(--font-display);font-size:16px">Print preview</div>
        <span style="color:#897F6B;font-size:13px">Ritual sheet · A4 portrait</span>
        <div style="margin-left:auto;display:flex;align-items:center;gap:10px;font-size:13px;color:#BCB29D">
          <span style="display:flex;align-items:center;gap:7px;padding:7px 12px;border:1px solid rgba(236,229,214,.12);border-radius:8px">Paper <strong style="color:#ECE5D6;font-weight:400">A4</strong></span>
          <span style="display:flex;align-items:center;gap:7px;padding:7px 12px;border:1px solid rgba(236,229,214,.12);border-radius:8px">Margins <strong style="color:#ECE5D6;font-weight:400">Normal</strong></span>
          <span style="display:flex;align-items:center;gap:7px;padding:7px 12px;border:1px solid rgba(236,229,214,.12);border-radius:8px">Ornament <strong style="color:#ECE5D6;font-weight:400">On</strong></span>
          <button type="button" class="print-btn" onclick="window.print()" style="display:flex;align-items:center;gap:8px;padding:8px 18px;border-radius:8px;background:#C7A24C;color:#15120D;font-weight:700;font-size:13px;border:none;cursor:pointer;transition:opacity .15s ease">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V3h12v6M6 18H4a2 2 0 0 1-2-2v-4a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-2M7 14h10v7H7z"></path></svg>
            Print
          </button>
        </div>
      </div>

      <!-- SURROUND -->
      <div class="surround scroll" style="flex:1;overflow-y:auto;background:#17140F;padding:36px 24px;display:flex;justify-content:center">
        <!-- SHEET -->
        <div class="sheet" style="width:760px;min-height:1075px;flex:none;background:var(--paper);color:var(--ink);box-shadow:0 24px 60px rgba(0,0,0,.55);padding:70px 72px;font-family:var(--font-display);position:relative">

          <!-- header -->
          <div style="text-align:center;margin-bottom:30px">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" style="margin-bottom:14px" aria-hidden="true">
              <circle cx="20" cy="20" r="17.5" stroke="var(--seal)" stroke-width="1.3"></circle>
              <circle cx="20" cy="20" r="12" stroke="var(--seal)" stroke-width=".8" opacity=".5"></circle>
              <line x1="9.5" y1="20" x2="30.5" y2="20" stroke="var(--seal)" stroke-width="1.3"></line>
            </svg>
            <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.26em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:14px">From the Vault of Theophrastos · Adeptus Minor</div>
            <h1 style="font-family:var(--font-display);font-weight:700;font-size:34px;line-height:1.12;margin:0;color:var(--ink)">The Lesser Banishing Ritual<br>of the Pentagram</h1>
            <div style="font-family:var(--font-display);font-style:italic;font-size:17px;color:var(--ink-soft);margin-top:8px">for daily practice — <span style="font-variant:small-caps">solve et coagula</span></div>
          </div>

          <div style="display:flex;align-items:center;gap:14px;margin-bottom:30px">
            <span style="flex:1;height:1px;background:var(--rule)"></span>
            <span style="font-family:var(--font-glyph);color:var(--seal);font-size:15px">❖</span>
            <span style="flex:1;height:1px;background:var(--rule)"></span>
          </div>

          <!-- section I -->
          <h2 style="font-family:var(--font-display);font-size:15px;letter-spacing:.16em;text-transform:uppercase;color:var(--seal);margin:0 0 14px">I · The Qabalistic Cross</h2>
          <p style="font-family:var(--font-display);font-size:16px;line-height:1.66;color:var(--ink);margin:0 0 26px;text-align:justify;text-wrap:pretty"><span style="float:left;font-family:var(--font-display);font-weight:700;font-size:56px;line-height:.78;padding:7px 11px 0 0;color:var(--seal)">F</span>acing East, touch the forehead and vibrate <strong style="font-weight:700">Ateh</strong> (<span lang="he" dir="rtl" style="font-family:var(--font-hebrew)">אַתָּה</span>) — <span style="font-style:italic">Unto Thee</span>. Touch the breast, <strong style="font-weight:700">Malkuth</strong> (<span lang="he" dir="rtl" style="font-family:var(--font-hebrew)">מַלְכוּת</span>) — <span style="font-style:italic">the Kingdom</span>. The right shoulder, <strong style="font-weight:700">ve-Geburah</strong> — <span style="font-style:italic">and the Power</span>. The left shoulder, <strong style="font-weight:700">ve-Gedulah</strong> — <span style="font-style:italic">and the Glory</span>. Clasp the hands, <strong style="font-weight:700">le-Olahm, Amen</strong>.</p>

          <!-- section II -->
          <h2 style="font-family:var(--font-display);font-size:15px;letter-spacing:.16em;text-transform:uppercase;color:var(--seal);margin:0 0 14px">II · The Formulation of the Pentagrams</h2>
          <p style="font-family:var(--font-display);font-size:16px;line-height:1.66;color:var(--ink);margin:0 0 22px;text-align:justify;text-wrap:pretty">Trace toward each quarter the banishing pentagram of Earth, beginning at the lower-left point. Vibrate the Name as you pierce the centre, and carry the line of light around to the next quarter.</p>

          <!-- diagram + quarter names -->
          <div style="display:flex;align-items:center;gap:34px;justify-content:center;margin:6px 0 30px;flex-wrap:wrap">
            <svg width="190" height="190" viewBox="0 0 200 200" style="flex:none" aria-hidden="true">
              <circle cx="100" cy="100" r="86" fill="none" stroke="var(--rule)" stroke-width="1.2"></circle>
              <path d="M100 30 L141.1 156.6 L33.4 78.4 L166.6 78.4 L58.9 156.6 Z" fill="none" stroke="var(--seal)" stroke-width="1.6" stroke-linejoin="round"></path>
              <circle cx="58.9" cy="156.6" r="3.2" fill="var(--seal)"></circle>
              <path d="M58.9 152 l-4 8" stroke="var(--seal)" stroke-width="1.2" stroke-linecap="round"></path>
            </svg>
            <table style="border-collapse:collapse;font-family:var(--font-display);font-size:15px;color:var(--ink)">
              <tr><td style="padding:6px 16px 6px 0;color:var(--ink-soft);font-style:italic">East · Air</td><td style="padding:6px 0"><span lang="he" dir="rtl" style="font-family:var(--font-hebrew);font-size:18px">יהוה</span> &nbsp;Yod He Vau He</td></tr>
              <tr><td style="padding:6px 16px 6px 0;color:var(--ink-soft);font-style:italic">South · Fire</td><td style="padding:6px 0"><span lang="he" dir="rtl" style="font-family:var(--font-hebrew);font-size:18px">אדני</span> &nbsp;Adonai</td></tr>
              <tr><td style="padding:6px 16px 6px 0;color:var(--ink-soft);font-style:italic">West · Water</td><td style="padding:6px 0"><span lang="he" dir="rtl" style="font-family:var(--font-hebrew);font-size:18px">אהיה</span> &nbsp;Eheieh</td></tr>
              <tr><td style="padding:6px 16px 6px 0;color:var(--ink-soft);font-style:italic">North · Earth</td><td style="padding:6px 0"><span lang="he" dir="rtl" style="font-family:var(--font-hebrew);font-size:18px">אגלא</span> &nbsp;Agla</td></tr>
            </table>
          </div>

          <p style="font-family:var(--font-display);font-size:16px;line-height:1.66;color:var(--ink);margin:0 0 8px;text-align:justify;text-wrap:pretty">Extend the arms in the sign of the cross and say: <span style="font-style:italic">Before me Raphael; behind me Gabriel; on my right hand Michael; on my left hand Auriel. For about me flames the pentagram, and in the column shines the six-rayed star.</span></p>

          <!-- footer -->
          <div style="position:absolute;left:72px;right:72px;bottom:54px">
            <div style="height:1px;background:var(--rule);margin-bottom:12px"></div>
            <div style="display:flex;justify-content:space-between;font-family:var(--font-ui);font-size:11px;letter-spacing:.04em;color:var(--ink-mute)">
              <span>Theophrastos · 20 June 2026 · <span style="font-family:var(--font-glyph)">♀</span> Hour of Venus</span>
              <span style="font-style:italic;font-family:var(--font-display)">Γνῶθι σαυτόν</span>
              <span>fol. i</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </body>
</html>
