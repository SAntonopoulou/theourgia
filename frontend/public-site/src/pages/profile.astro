---
/**
 * Profile — per-identity public face.
 *
 * Faithful port of ``Theourgia Profile.dc.html``. Per
 * ``agent_onboarding.md`` § Theourgia Profile.dc.html:
 *   · Route ``/@identity`` (this build serves a single demo at ``/profile``
 *     until the Identity model ships).
 *   · Public chrome, page-scroll. Owner sees a preview-as banner that lets
 *     them flip between identities — that banner is owner-only.
 *   · Three personas demonstrated to cover the matrix:
 *       Theo       — verified, signed, lineage attestations
 *       Frater     — verified, signed under a motto
 *       null.priest — unsigned, no lineage (intentional state)
 *   · Verified-key card + each attestation's state are real signature
 *     checks (§10.5). For now the verify button is stubbed.
 *
 * **Unlinkability is non-negotiable.** The preview-as switcher is owner-
 * only; it must not change what the public actually sees. We render all
 * three personas in the DOM here only because there is no real identity
 * yet — once the Identity model lands, the public route serves a single
 * identity's data and the banner only appears for the vault owner.
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const MAXW = "1080px";

interface Writing {
  kind: string;
  title: string;
  blurb: string;
  meta: string;
}

interface Attestation {
  glyph: string;
  claim: string;
  status: string;
  statusTone: "success" | "mute";
  year: string;
}

interface Persona {
  id: "theo" | "frater" | "nullp";
  glyph: string;
  name: string;
  role: string;
  bio: string;
  since: string;
  tradition: string;
  lang: string;
  verified: boolean;
  attestedBy: string;
  key: string;
  maxim: string;
  writingCount: string;
  writings: Writing[];
  attestations: Attestation[];
}

// Persona data — copied verbatim from Theourgia Profile.dc.html lines 208-258.
// Curly apostrophes preserved (the designer's editorial copy uses ’).
const PERSONAS: Persona[] = [
  {
    id: "theo",
    glyph: "Θ",
    name: "Theophrastos",
    role: "Theurgist · Neoplatonist",
    bio: "I keep a public notebook on theurgic practice in the Hellenic and Neoplatonic current — Iamblichus, Proclus, the Chaldean Oracles — read closely and tested in the work. Method over mystery; the record over the rumour.",
    since: "Practising since 2014",
    tradition: "Hellenic theurgy",
    lang: "Greek · English",
    verified: true,
    attestedBy: "Attested by Ordo Theurgica",
    key: "ed25519  4B1C·0FA9·77E2·5C6A",
    maxim: "Γνῶθι σαυτόν — Know thyself.",
    writingCount: "24 essays · 9 years",
    writings: [
      { kind: "Essay · 18 Jun", title: "On the discipline of the magical record", blurb: "Why the notebook outlasts the working, and what dated entries teach about one’s own credulity.", meta: "12 min · 92 notes" },
      { kind: "Essay · 6 Jun", title: "Planetary hours for people who don’t believe in them", blurb: "A pragmatic case for ritual timing as attention-shaping, not astral mechanics.", meta: "9 min · 61 notes" },
      { kind: "Essay · 21 May", title: "Hekate at the crossroads of three traditions", blurb: "Reconciling the PGM, Orphic, and Chaldean Hekate without flattening them into one.", meta: "14 min · 88 notes" },
      { kind: "Note · 9 May", title: "A reading of the first Chaldean fragment", blurb: "“There exists a certain Intelligible which thou must perceive by the flower of mind.”", meta: "5 min · 30 notes" },
    ],
    attestations: [
      { glyph: "☿", claim: "Adeptus Minor, R.R. et A.C.", status: "Self-declared", statusTone: "mute", year: "2019" },
      { glyph: "☉", claim: "Trained under K. Theodorou", status: "Counter-signed", statusTone: "success", year: "2016" },
      { glyph: "✦", claim: "Member, Ordo Theurgica", status: "Verified", statusTone: "success", year: "2015" },
    ],
  },
  {
    id: "frater",
    glyph: "✠",
    name: "Frater Sub Rosā",
    role: "O.T.O. · V° Sovereign Prince of Rome",
    bio: "Thelemic essays and lodge notices, written under my motto. The Law is for all; the man behind the name is not your concern. I publish what is fit to publish and seal the rest.",
    since: "Initiated 2011",
    tradition: "Thelema · O.T.O.",
    lang: "English",
    verified: true,
    attestedBy: "Attested by O.T.O. Grand Lodge",
    key: "ed25519  D5E8·11B7·A24F·90C3",
    maxim: "Do what thou wilt shall be the whole of the Law.",
    writingCount: "11 essays · lodge notices",
    writings: [
      { kind: "Essay · 16 Jun", title: "Liber Resh and the architecture of a day", blurb: "Four adorations as scaffolding for attention — read as discipline, not devotion.", meta: "8 min · 54 notes" },
      { kind: "Notice · 10 Jun", title: "Gnostic Mass — open celebration, solstice", blurb: "The lodge celebrates the Mass on the solstice. Visitors in good standing are welcome.", meta: "Lodge notice" },
      { kind: "Essay · 2 Jun", title: "On the word of Sin, and being misread", blurb: "Why the Thelemic Law is read as licence by those who never finish the sentence.", meta: "11 min · 70 notes" },
    ],
    attestations: [
      { glyph: "✠", claim: "V° — Sovereign Prince of Rome", status: "Counter-signed", statusTone: "success", year: "2018" },
      { glyph: "△", claim: "III° — Knight of the East and West", status: "Counter-signed", statusTone: "success", year: "2014" },
      { glyph: "☉", claim: "Initiated, O.T.O. Grand Lodge", status: "Verified", statusTone: "success", year: "2011" },
    ],
  },
  {
    id: "nullp",
    glyph: "∅",
    name: "null.priest",
    role: "Unattributed · chaos current",
    bio: "Chaos work, posted and abandoned. There is no identity here to verify and no lineage to trace. Take what is useful; leave the rest. Belief is a tool, and so is anonymity.",
    since: "—",
    tradition: "Chaos magic",
    lang: "—",
    verified: false,
    attestedBy: "",
    key: "",
    maxim: "Nothing is true.",
    writingCount: "unsigned notes",
    writings: [
      { kind: "Note · undated", title: "A sigil method that survives its author", blurb: "Charge, forget, sever. The working that needs no one to remember making it.", meta: "unsigned" },
      { kind: "Note · undated", title: "Against lineage", blurb: "On why some currents are weakened, not strengthened, by a chain of names.", meta: "unsigned" },
    ],
    attestations: [],
  },
];

const toneToColor = (tone: "success" | "mute") =>
  tone === "success" ? "var(--success)" : "var(--ink-mute)";
---

<BaseLayout title="Public profile — Theourgia">
  <div id="profile-root" data-who="theo" style={`min-height:100vh;background:var(--bg);color:var(--ink);font-family:var(--font-serif)`}>

    <!-- OWNER PREVIEW BANNER (owner-only in production; demo always shows for now) -->
    <div id="preview-banner" role="region" aria-label="Preview notice" style="background:color-mix(in srgb, var(--info) 14%, var(--bg-2));border-bottom:1px solid var(--line-2)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:11px 28px;display:flex;align-items:center;gap:16px;flex-wrap:wrap`}>
        <span style="display:flex;align-items:center;gap:9px;color:var(--info);flex:none">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3.2"></circle><path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12z"></path></svg>
        </span>
        <span style="font-family:var(--font-ui);font-size:13px;color:var(--ink);min-width:0">You're previewing a public face. Visitors see exactly this — and never learn which other identities share your vault.</span>
        <div role="group" aria-label="Preview as identity" style="margin-left:auto;display:flex;align-items:center;gap:7px">
          <span style="font-family:var(--font-ui);font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;color:var(--ink-mute)">Preview as</span>
          <button type="button" data-pv data-pick="theo" aria-pressed="true" style="display:flex;align-items:center;gap:6px;padding:5px 10px;border:1px solid var(--line);border-radius:999px;font-family:var(--font-ui);font-size:12px;color:var(--ink-soft);background:transparent;cursor:pointer">
            <span style="font-family:var(--font-glyph);color:var(--accent);font-size:12px">Θ</span>Theophrastos
          </button>
          <button type="button" data-pv data-pick="frater" aria-pressed="false" style="display:flex;align-items:center;gap:6px;padding:5px 10px;border:1px solid var(--line);border-radius:999px;font-family:var(--font-ui);font-size:12px;color:var(--ink-soft);background:transparent;cursor:pointer">
            <span style="font-family:var(--font-glyph);color:var(--accent);font-size:11px">✠</span>Frater Sub Rosā
          </button>
          <button type="button" data-pv data-pick="nullp" aria-pressed="false" style="display:flex;align-items:center;gap:6px;padding:5px 10px;border:1px solid var(--line);border-radius:999px;font-family:var(--font-mono);font-size:11.5px;color:var(--ink-soft);background:transparent;cursor:pointer">
            <span style="font-family:var(--font-glyph);font-size:11px">∅</span>null.priest
          </button>
          <button type="button" data-banner-close aria-label="Dismiss preview notice" class="banner-close" style="display:flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:var(--r-sm);color:var(--ink-mute);background:transparent;border:none;cursor:pointer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"></path></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- PUBLIC HEADER (identity-scoped) -->
    <header style="border-bottom:1px solid var(--line);background:var(--bg);position:sticky;top:0;z-index:20">
      <div style={`max-width:${MAXW};margin:0 auto;padding:16px 28px;display:flex;align-items:center;gap:22px`}>
        <a href="#about" style="display:flex;align-items:center;gap:11px;text-decoration:none;color:inherit">
          <svg width="27" height="27" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <circle cx="20" cy="20" r="17.5" stroke="var(--accent)" stroke-width="1.4"></circle>
            <line x1="9.5" y1="20" x2="30.5" y2="20" stroke="var(--accent)" stroke-width="1.4"></line>
          </svg>
          {PERSONAS.map((p) => (
            <span data-persona={p.id} class="persona-block" style="font-family:var(--font-display);font-size:19px;letter-spacing:.03em">{p.name}</span>
          ))}
        </a>
        <nav class="om-pubnav" style="display:flex;gap:20px;margin-left:6px;font-family:var(--font-ui);font-size:13.5px;color:var(--ink-soft)">
          <a href="#writings" class="pub-nav-link" style="text-decoration:none;color:inherit">Writings</a>
          <a href="#lineage" class="pub-nav-link" style="text-decoration:none;color:inherit">Lineage</a>
          <a href="#about" class="pub-nav-link" style="text-decoration:none;color:inherit">About</a>
        </nav>
        <div style="margin-left:auto;display:flex;align-items:center;gap:11px">
          <div role="group" aria-label="Theme" class="om-pubseg theme-cycler" style="display:flex;gap:2px;padding:3px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2)">
            <button type="button" data-theme-pick="base" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Base</button>
            <button type="button" data-theme-pick="hellenic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Hel</button>
            <button type="button" data-theme-pick="thelemic" class="seg-btn" style="padding:5px 11px;font-family:var(--font-ui);font-size:12px;letter-spacing:.03em;color:var(--ink-mute);background:transparent;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all .15s ease">Thel</button>
          </div>
          <button type="button" data-mode-toggle aria-label="Toggle light and dark" class="mode-toggle" style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;border:1px solid var(--line);border-radius:8px;background:var(--bg-2);color:var(--ink-soft);cursor:pointer">
            <span data-mode-icon aria-hidden="true" style="display:inline-flex"></span>
          </button>
          <button type="button" class="follow-cta" style="padding:8px 15px;border-radius:var(--r-md);background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-weight:700;font-size:13px;border:none;cursor:pointer">Follow</button>
        </div>
      </div>
    </header>

    <!-- IDENTITY HERO -->
    <section id="about" style="border-bottom:1px solid var(--line);background:var(--bg-2)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:46px 28px 40px;display:flex;gap:34px;align-items:flex-start;flex-wrap:wrap`}>
        {PERSONAS.map((p) => (
          <div
            data-persona={p.id}
            class="persona-avatar"
            style="width:120px;height:120px;border-radius:50%;background:var(--bg);border:1px solid var(--line-2);display:flex;align-items:center;justify-content:center;font-family:var(--font-glyph);color:var(--accent);font-size:58px;flex:none;box-shadow:inset 0 0 0 6px var(--accent-soft)"
          >{p.glyph}</div>
        ))}
        <div style="flex:1 1 420px;min-width:0">
          {PERSONAS.map((p) => (
            <div data-persona={p.id} class="persona-block">
              <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:6px">
                <h1 style="font-family:var(--font-display);font-weight:700;font-size:clamp(34px,5vw,50px);line-height:1;margin:0;letter-spacing:-.01em">{p.name}</h1>
                {p.verified ? (
                  <span title="Identity signature verified" style="display:inline-flex;align-items:center;gap:6px;font-family:var(--font-ui);font-size:12px;color:var(--success);padding:4px 10px;border:1px solid var(--line);border-radius:999px;background:var(--bg)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"></path><path d="M9 12l2 2 4-4"></path></svg>
                    Verified
                  </span>
                ) : (
                  <span title="No verifiable identity" style="display:inline-flex;align-items:center;gap:6px;font-family:var(--font-ui);font-size:12px;color:var(--ink-mute);padding:4px 10px;border:1px dashed var(--line-2);border-radius:999px">Unsigned · anonymous</span>
                )}
              </div>
              <div style="font-family:var(--font-display);font-size:18px;color:var(--ink-soft);margin-bottom:18px">{p.role}</div>
              <p style="font-size:17px;line-height:1.62;color:var(--ink-soft);max-width:60ch;margin:0 0 22px">{p.bio}</p>
              <div style="display:flex;gap:22px;flex-wrap:wrap;font-family:var(--font-ui);font-size:13px;color:var(--ink-mute)">
                <span style="display:flex;align-items:center;gap:7px">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                  {p.since}
                </span>
                <span style="display:flex;align-items:center;gap:7px">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h10"></path></svg>
                  {p.tradition}
                </span>
                <span style="display:flex;align-items:center;gap:7px">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"></path></svg>
                  {p.lang}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BODY -->
    <section>
      <div style={`max-width:${MAXW};margin:0 auto;padding:40px 28px 72px;display:flex;gap:40px;align-items:flex-start;flex-wrap:wrap`}>

        <!-- LEFT: writings -->
        <div id="writings" style="flex:2 1 440px;min-width:0">
          <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:22px">
            <h2 style="font-family:var(--font-display);font-size:24px;margin:0">Public writings</h2>
            {PERSONAS.map((p) => (
              <span data-persona={p.id} class="persona-block" style="font-family:var(--font-ui);font-size:12.5px;color:var(--ink-mute)">{p.writingCount}</span>
            ))}
          </div>
          {PERSONAS.map((p) => (
            <div data-persona={p.id} class="persona-block">
              <div style="display:flex;flex-direction:column;border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden;background:var(--bg-2)">
                {p.writings.map((w, i) => (
                  <a
                    href="/essay"
                    class="profile-writing"
                    style={`display:flex;flex-direction:column;gap:9px;padding:22px 24px${i < p.writings.length - 1 ? ";border-bottom:1px solid var(--line)" : ""};text-decoration:none;color:inherit`}
                  >
                    <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent)">{w.kind}</div>
                    <h3 style="font-family:var(--font-display);font-size:22px;line-height:1.2;margin:0">{w.title}</h3>
                    <p style="font-size:14.5px;line-height:1.55;color:var(--ink-soft);margin:0">{w.blurb}</p>
                    <div style="font-family:var(--font-ui);font-size:12px;color:var(--ink-mute);margin-top:2px">{w.meta}</div>
                  </a>
                ))}
              </div>
              {!p.verified ? (
                <p style="font-family:var(--font-ui);font-size:12.5px;color:var(--ink-mute);font-style:italic;margin:16px 2px 0;line-height:1.5">These notes carry no signature. Nothing proves they came from the same hand twice — that is the point.</p>
              ) : null}
            </div>
          ))}
        </div>

        <!-- RIGHT: sidebar -->
        <aside style="flex:1 1 280px;min-width:0;display:flex;flex-direction:column;gap:18px">

          <!-- signing key -->
          {PERSONAS.map((p) => (
            <div data-persona={p.id} class="persona-block" style="background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px">
              <div style="font-family:var(--font-ui);font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:13px">Identity signature</div>
              {p.verified ? (
                <div>
                  <div style="display:flex;align-items:center;gap:9px;margin-bottom:10px">
                    <span style="display:flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:50%;background:color-mix(in srgb, var(--success) 18%, transparent);color:var(--success);flex:none">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.5 4.5L19 6.5"></path></svg>
                    </span>
                    <div style="font-family:var(--font-ui);font-size:13px;color:var(--ink);line-height:1.2">
                      Verified<br><span style="font-size:11.5px;color:var(--ink-mute)">{p.attestedBy}</span>
                    </div>
                  </div>
                  <div style="display:flex;align-items:center;gap:8px;padding:9px 11px;border:1px solid var(--line);border-radius:var(--r-md);background:var(--bg);font-family:var(--font-mono);font-size:11.5px;color:var(--ink-soft);word-break:break-all">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ink-mute)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="flex:none"><circle cx="7.5" cy="15.5" r="4"></circle><path d="M10.5 12.5 20 3M16 7l2.5 2.5M18.5 4.5 21 7"></path></svg>
                    {p.key}
                  </div>
                  <button type="button" class="verify-sig" style="font-family:var(--font-ui);font-size:12px;color:var(--accent);margin-top:11px;background:transparent;border:none;cursor:pointer;padding:0">Verify this signature →</button>
                </div>
              ) : (
                <div style="display:flex;align-items:flex-start;gap:10px;font-family:var(--font-ui);font-size:13px;line-height:1.5;color:var(--ink-soft)">
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--ink-mute)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="flex:none;margin-top:1px"><circle cx="12" cy="12" r="9"></circle><path d="M9.2 9a3 3 0 0 1 5.5 1c0 2-3 2.5-3 4M12 17h.01"></path></svg>
                  No signing key. This identity is intentionally severed — it cannot be cryptographically tied to anyone, including its own past posts.
                </div>
              )}
            </div>
          ))}

          <!-- lineage / attestations -->
          {PERSONAS.map((p) => (
            <div data-persona={p.id} class="persona-block" id={p.id === "theo" ? "lineage" : undefined} style="background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
                <span style="font-family:var(--font-ui);font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mute)">Lineage &amp; attestations</span>
              </div>
              {p.attestations.length === 0 ? (
                <div style="font-family:var(--font-serif);font-size:14px;line-height:1.55;color:var(--ink-mute);font-style:italic">This identity makes no public attestations. No lineage, no degrees, no teachers — by design.</div>
              ) : (
                <>
                  {p.attestations.map((a, i) => (
                    <div style={`display:flex;gap:11px;padding:11px 0${i < p.attestations.length - 1 ? ";border-bottom:1px solid var(--line)" : ""}`}>
                      <span style="font-family:var(--font-glyph);color:var(--accent);font-size:15px;flex:none;margin-top:1px">{a.glyph}</span>
                      <div style="min-width:0">
                        <div style="font-family:var(--font-serif);font-size:15px;line-height:1.3;color:var(--ink)">{a.claim}</div>
                        <div style="display:flex;align-items:center;gap:7px;margin-top:4px">
                          <span style={`font-family:var(--font-ui);font-size:11px;color:${toneToColor(a.statusTone)};white-space:nowrap`}>{a.status}</span>
                          <span style="font-family:var(--font-ui);font-size:11px;color:var(--ink-mute)">· {a.year}</span>
                        </div>
                      </div>
                    </div>
                  ))}
                  {p.verified ? (
                    <a href="/lineage" class="lineage-link" style="display:inline-flex;align-items:center;gap:7px;font-family:var(--font-ui);font-size:12.5px;color:var(--accent);margin-top:13px;text-decoration:none">See full lineage web →</a>
                  ) : null}
                </>
              )}
            </div>
          ))}

          <!-- subscribe (only when verified) -->
          {PERSONAS.map((p) => (
            p.verified ? (
              <div data-persona={p.id} class="persona-block" style="background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r-lg);padding:18px 20px">
                <div style="font-family:var(--font-display);font-size:17px;margin-bottom:6px">Follow {p.name}</div>
                <p style="font-family:var(--font-ui);font-size:12.5px;line-height:1.5;color:var(--ink-mute);margin:0 0 14px">New writings by email or RSS. No tracking, no list-selling.</p>
                <div style="display:flex;gap:9px">
                  <button type="button" class="profile-subscribe" style="flex:1;padding:9px 14px;border-radius:var(--r-md);background:var(--accent);color:var(--accent-ink);font-family:var(--font-ui);font-weight:700;font-size:12.5px;border:none;cursor:pointer">Subscribe</button>
                  <a href="/rss.xml" aria-label="RSS feed" style="display:flex;align-items:center;justify-content:center;width:40px;border:1px solid var(--line-2);border-radius:var(--r-md);color:var(--ink-soft);text-decoration:none">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="6.2" cy="17.8" r="1.6" fill="currentColor" stroke="none"></circle><path d="M5 12a7 7 0 0 1 7 7M5 6a13 13 0 0 1 13 13" stroke-linecap="round"></path></svg>
                  </a>
                </div>
              </div>
            ) : null
          ))}

        </aside>
      </div>
    </section>

    <!-- FOOTER -->
    <footer style="border-top:1px solid var(--line);background:var(--bg-2)">
      <div style={`max-width:${MAXW};margin:0 auto;padding:34px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px`}>
        {PERSONAS.map((p) => (
          <div data-persona={p.id} class="persona-block" style="font-family:var(--font-display);font-style:italic;font-size:16px;color:var(--ink-soft)">{p.maxim}</div>
        ))}
        <div style="font-family:var(--font-ui);font-size:12px;color:var(--ink-mute)">A public face, kept in Theourgia.</div>
      </div>
    </footer>

  </div>
</BaseLayout>

<style>
  /* Persona swap — visibility driven solely by the parent #profile-root's
     [data-who] attribute. Non-active persona blocks are hidden; the active
     one keeps its natural display value (block for .persona-block, flex
     for .persona-avatar). */
  #profile-root[data-who="theo"]   [data-persona]:not([data-persona="theo"])   { display: none !important; }
  #profile-root[data-who="frater"] [data-persona]:not([data-persona="frater"]) { display: none !important; }
  #profile-root[data-who="nullp"]  [data-persona]:not([data-persona="nullp"])  { display: none !important; }

  /* Preview-button selected state. */
  [data-pv][aria-pressed="true"] {
    background: var(--accent-soft);
    border-color: var(--accent) !important;
    color: var(--ink) !important;
  }

  /* Theme cycler selected state. */
  .seg-btn[data-selected="true"] {
    color: var(--ink) !important;
    background: var(--accent-soft) !important;
    border-color: var(--line-2) !important;
  }

  /* Hover states. */
  .pub-nav-link { transition: color 0.15s ease; }
  .pub-nav-link:hover { color: var(--ink); }
  .follow-cta:hover { opacity: 0.9; }
  .mode-toggle:hover { color: var(--ink); }
  .banner-close:hover { color: var(--ink); background: var(--bg-3); }
  .profile-writing { transition: background-color 0.15s ease; }
  .profile-writing:hover { background: var(--bg-3); }
  .verify-sig:hover { opacity: 0.8; }
  .lineage-link { transition: gap 0.15s ease; }
  .lineage-link:hover { gap: 11px !important; }
  .profile-subscribe:hover { opacity: 0.9; }

  /* Responsive — match Profile.dc.html's @media rules. */
  @media (max-width: 860px) { .om-pubnav { display: none !important; } }
  @media (max-width: 600px) { .om-pubseg { display: none !important; } }
</style>

<script>
  // ============================================================================
  // Profile interactivity
  // ----------------------------------------------------------------------------
  //   · Preview-as swap (3 personas pre-rendered; switch via [data-who] root)
  //   · Banner dismiss
  //   · Theme cycler (Base / Hellenic / Thelemic)
  //   · Mode toggle (dark / light)
  //   · Verify-signature button — stubbed until §10.5 key fetch ships.
  // ============================================================================
  type Persona = "theo" | "frater" | "nullp";
  type Theme = "base" | "hellenic" | "thelemic";
  type Mode = "dark" | "light";

  const root = document.getElementById("profile-root");
  const banner = document.getElementById("preview-banner");
  if (!root) throw new Error("profile-root missing");

  // -- Persona swap ---------------------------------------------------------
  const isPersona = (v: string | null): v is Persona =>
    v === "theo" || v === "frater" || v === "nullp";

  const setPersona = (next: Persona) => {
    root.setAttribute("data-who", next);
    document.querySelectorAll<HTMLElement>("[data-pv][data-pick]").forEach((btn) => {
      btn.setAttribute("aria-pressed", btn.getAttribute("data-pick") === next ? "true" : "false");
    });
  };

  document.querySelectorAll<HTMLElement>("[data-pv][data-pick]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const pick = btn.getAttribute("data-pick");
      if (isPersona(pick)) setPersona(pick);
    });
  });

  // -- Banner dismiss -------------------------------------------------------
  document.querySelector<HTMLElement>("[data-banner-close]")?.addEventListener("click", () => {
    if (banner) banner.style.display = "none";
  });

  // -- Theme cycler ---------------------------------------------------------
  const MOON_PATH = "M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z";
  const SUN_GROUP = `<circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path>`;

  const getTheme = (): Theme => {
    const v = document.documentElement.getAttribute("data-theme");
    return v === "hellenic" || v === "thelemic" ? v : "base";
  };
  const getMode = (): Mode =>
    document.documentElement.getAttribute("data-mode") === "light" ? "light" : "dark";

  const setTheme = (theme: Theme) => {
    document.documentElement.setAttribute("data-theme", theme);
    try { localStorage.setItem("theourgia.theme", theme); } catch (_) { /* noop */ }
    syncChrome();
  };
  const setMode = (mode: Mode) => {
    document.documentElement.setAttribute("data-mode", mode);
    try { localStorage.setItem("theourgia.mode", mode); } catch (_) { /* noop */ }
    syncChrome();
  };

  const svgFor = (mode: Mode) =>
    mode === "dark"
      ? `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="${MOON_PATH}"></path></svg>`
      : `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${SUN_GROUP}</svg>`;

  const syncChrome = () => {
    const theme = getTheme();
    const mode = getMode();
    document.querySelectorAll<HTMLElement>("[data-theme-pick]").forEach((el) => {
      const matches = el.getAttribute("data-theme-pick") === theme;
      el.setAttribute("data-selected", matches ? "true" : "false");
      el.setAttribute("aria-pressed", matches ? "true" : "false");
    });
    document.querySelectorAll<HTMLElement>("[data-mode-icon]").forEach((el) => {
      el.innerHTML = svgFor(mode);
    });
  };

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    const themePick = target.closest<HTMLElement>("[data-theme-pick]");
    if (themePick) {
      const t = themePick.getAttribute("data-theme-pick");
      if (t === "base" || t === "hellenic" || t === "thelemic") setTheme(t);
      return;
    }
    const modeToggle = target.closest<HTMLElement>("[data-mode-toggle]");
    if (modeToggle) setMode(getMode() === "dark" ? "light" : "dark");
  });

  syncChrome();

  // -- Verify signature (stub) ----------------------------------------------
  // Real impl will run an in-browser ed25519 key fetch + signature validate
  // (§10.5). For now the click acknowledges via a soft inline note so the
  // affordance is testable without the backing endpoint.
  document.querySelectorAll<HTMLButtonElement>(".verify-sig").forEach((btn) => {
    btn.addEventListener("click", () => {
      const original = btn.textContent;
      btn.textContent = "Signature endpoint not yet wired ·";
      btn.style.color = "var(--ink-mute)";
      setTimeout(() => {
        if (original) btn.textContent = original;
        btn.style.color = "var(--accent)";
      }, 2200);
    });
  });
</script>
