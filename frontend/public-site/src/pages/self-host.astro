---
/**
 * Self-host — public-site marketing / doc page.
 *
 * Landing target for the footer's Community › "Self-host guide" link.
 * Explains how to run your own Theourgia instance, why you might
 * want to, and where the documentation lives.
 *
 * AGPLv3 is the core commitment: whoever runs Theourgia must offer
 * their users the source code. This page states that plainly.
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const MAXW = "820px";

const WHY = [
  {
    title: "You own the substrate",
    body:
      "Your journal, your entities, your practice records — the whole vault — lives on hardware you control. No dependency on any single operator, including the person who currently runs theourgia.com.",
  },
  {
    title: "You choose the trust boundary",
    body:
      "The person who runs your instance can see whatever you haven't marked sealed. Choose someone you trust that far — or be that person yourself.",
  },
  {
    title: "You keep pace with the upstream",
    body:
      "Pull upstream changes when they land; hold back when a release doesn't suit you. Fork the code if you disagree with the project's direction. The AGPLv3 licence guarantees you always can.",
  },
  {
    title: "You can host others",
    body:
      "If you run an instance, you can host other practitioners on it. Your trusted circle, your coven, your order. The multi-user model + hub system was designed for exactly this.",
  },
];

const STACK = [
  ["Python 3.12+", "backend (FastAPI + SQLModel + Alembic)"],
  ["PostgreSQL 16+", "database (with the pgvector + CITEXT extensions)"],
  ["Redis 7+", "cache + background job queue"],
  ["Node 20+", "frontend build (Astro + React 19)"],
  ["A modern browser", "SPA runtime — Chrome, Safari, Firefox, or Edge"],
  ["A domain name", "and TLS certificate (Let's Encrypt is fine)"],
  ["~2 GB RAM", "minimum for the app containers (a small VPS suffices)"],
  ["~20 GB disk", "seed size; scales with your vault"],
];
---

<BaseLayout title="Self-host · Theourgia">
  <main
    style={`max-width:${MAXW};margin:0 auto;padding:64px clamp(16px,5vw,28px) 80px;display:flex;flex-direction:column;gap:56px`}
  >
    <a
      href="/"
      style="font-family:var(--font-ui);font-size:12px;color:var(--ink-mute);text-decoration:none;letter-spacing:.08em;text-transform:uppercase"
      >← Theourgia</a
    >

    <header style="display:flex;flex-direction:column;gap:14px">
      <span
        style="font-family:var(--font-ui);font-size:11.5px;color:var(--ink-mute);text-transform:uppercase;letter-spacing:.16em"
      >
        Run your own instance
      </span>
      <h1
        style="margin:0;font-family:var(--font-display);font-size:44px;letter-spacing:-0.01em;color:var(--ink);line-height:1.15"
      >
        Self-host
      </h1>
      <p
        style="margin:0;font-family:var(--font-serif);font-size:19px;line-height:1.55;color:var(--ink-soft);max-width:640px"
      >
        Theourgia is designed to be self-hosted. The theourgia.com host is one
        instance among many. Anyone can run their own — and the licence ensures
        anyone always will be able to.
      </p>
    </header>

    <section style="display:flex;flex-direction:column;gap:22px">
      <h2
        style="margin:0;font-family:var(--font-display);font-size:24px;color:var(--ink);letter-spacing:.01em"
      >
        Why self-host
      </h2>
      <div style="display:flex;flex-direction:column;gap:22px">
        {WHY.map((w) => (
          <div>
            <h3
              style="margin:0 0 8px 0;font-family:var(--font-display);font-size:18px;color:var(--ink);letter-spacing:.01em"
            >
              {w.title}
            </h3>
            <p
              style="margin:0;font-family:var(--font-serif);font-size:15px;line-height:1.6;color:var(--ink-soft)"
            >
              {w.body}
            </p>
          </div>
        ))}
      </div>
    </section>

    <section style="display:flex;flex-direction:column;gap:18px">
      <h2
        style="margin:0;font-family:var(--font-display);font-size:24px;color:var(--ink);letter-spacing:.01em"
      >
        What you'll need
      </h2>
      <div
        style="background-color:var(--bg-2);border:1px solid var(--line);border-radius:12px;padding:22px 26px"
      >
        <dl
          style="margin:0;display:grid;grid-template-columns:auto 1fr;gap:12px 22px;font-family:var(--font-ui);font-size:14px"
        >
          {STACK.map(([tech, purpose]) => (
            <>
              <dt style="color:var(--ink);font-family:var(--font-mono);font-size:13px">
                {tech}
              </dt>
              <dd style="margin:0;color:var(--ink-soft)">{purpose}</dd>
            </>
          ))}
        </dl>
      </div>
    </section>

    <section style="display:flex;flex-direction:column;gap:14px">
      <h2
        style="margin:0;font-family:var(--font-display);font-size:24px;color:var(--ink);letter-spacing:.01em"
      >
        Where the documentation lives
      </h2>
      <p
        style="margin:0;font-family:var(--font-serif);font-size:15px;line-height:1.6;color:var(--ink-soft)"
      >
        The deployment runbook, docker-compose files, and step-by-step guide
        for standing up a production instance live in the project's{" "}
        <a
          href="https://github.com/SAntonopoulou/theourgia"
          rel="noopener"
          style="color:var(--accent)"
          >source repository</a
        >
        . Start with{" "}
        <a
          href="https://github.com/SAntonopoulou/theourgia/blob/main/docs/ops/DEPLOYMENT_RUNBOOK.md"
          rel="noopener"
          style="color:var(--accent)"
          ><code>docs/ops/DEPLOYMENT_RUNBOOK.md</code></a
        >{" "}
        for the canonical procedure.
      </p>
      <p
        style="margin:0;font-family:var(--font-serif);font-size:15px;line-height:1.6;color:var(--ink-soft)"
      >
        If you get stuck, open a{" "}
        <a
          href="https://github.com/SAntonopoulou/theourgia/discussions"
          rel="noopener"
          style="color:var(--accent)"
          >discussion</a
        >{" "}
        — self-hosting friction is a first-class bug and gets fixed.
      </p>
    </section>

    <section
      style="border-top:1px solid var(--line);padding-top:32px;display:flex;flex-direction:column;gap:12px;background:var(--bg-2);border-radius:12px;padding:24px 26px;border:1px solid var(--line)"
    >
      <h2
        style="margin:0;font-family:var(--font-display);font-size:19px;color:var(--ink);letter-spacing:.01em"
      >
        A note on the licence
      </h2>
      <p
        style="margin:0;font-family:var(--font-serif);font-size:14.5px;line-height:1.6;color:var(--ink-soft)"
      >
        Theourgia is licensed under the{" "}
        <a
          href="https://www.gnu.org/licenses/agpl-3.0.en.html"
          rel="noopener"
          style="color:var(--accent)"
          >GNU Affero General Public License v3.0</a
        >
        . If you host Theourgia and modify the code, you must make your
        modified source available to your users. If you don't modify it, the
        upstream source at{" "}
        <a
          href="https://github.com/SAntonopoulou/theourgia"
          rel="noopener"
          style="color:var(--accent)"
          >github.com/SAntonopoulou/theourgia</a
        >{" "}
        is what you need to link to. This ensures the tool stays practitioner-
        owned, forever.
      </p>
    </section>
  </main>
</BaseLayout>
