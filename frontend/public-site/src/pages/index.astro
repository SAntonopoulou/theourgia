              <line x1="129.07" y1="179.87" x2="130.1" y2="182.69"></line>
              <line x1="122" y1="182.1" x2="122.78" y2="185"></line>
              <line x1="114.76" y1="183.71" x2="115.28" y2="186.66"></line>
              <line x1="107.41" y1="184.68" x2="107.67" y2="187.67"></line>
              <line x1="100" y1="182" x2="100" y2="188" stroke-width="1"></line>
              <line x1="92.59" y1="184.68" x2="92.33" y2="187.67"></line>
              <line x1="85.24" y1="183.71" x2="84.72" y2="186.66"></line>
