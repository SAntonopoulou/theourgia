        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" }, "editorMode": "code", "expr": "topk(10, sum by (path_template) (rate(theourgia_http_requests_total[5m])))", "legendFormat": "{{path_template}}", "refId": "A" }
      ],
      "title": "Top routes by request rate",
      "type": "timeseries"
