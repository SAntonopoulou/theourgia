<script>
  // PublicChrome ships the theme/mode cycler. Here we only need to sync
  // the tradition cards (which also pick a theme), since they live in
  // page content and not chrome.
  type Theme = "base" | "hellenic" | "thelemic";
  const getTheme = (): Theme => {
    const v = document.documentElement.getAttribute("data-theme");
    return v === "hellenic" || v === "thelemic" ? v : "base";
  };
  const syncCards = () => {
    const t = getTheme();
    document.querySelectorAll<HTMLElement>(".tradition-card").forEach((card) => {
      card.setAttribute(
        "data-selected",
        card.getAttribute("data-theme-pick") === t ? "true" : "false",
      );
    });
  };
  // Theme picks bubble up from anywhere on the page (chrome + tradition
  // cards both carry data-theme-pick). PublicChrome's delegated handler
  // applies the theme; we add a follow-up to re-sync our cards.
  document.addEventListener("click", (e) => {
    const target = (e.target as HTMLElement | null)?.closest<HTMLElement>("[data-theme-pick]");
    if (target) requestAnimationFrame(syncCards);
  });
  syncCards();
</script>
