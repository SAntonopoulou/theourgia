        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" }, "editorMode": "code", "expr": "sum by (outcome) (increase(theourgia_backup_runs_total[1h]))", "legendFormat": "{{outcome}}", "refId": "A" }
      ],
