---
/**
 * Trance Mode — scrying / visionary mode.
 *
 * Faithful port of ``Theourgia Trance Mode.dc.html``. Per
 * ``agent_onboarding.md`` § Theourgia Trance Mode.dc.html:
 *   · Minimal-chrome full-screen mode (no app shell, no theme cycler).
 *   · Low-blue-light palette — warm near-black + amber. This is a real
 *     color treatment, not a vibe; "dim" is achieved via the palette,
 *     not by dropping below contrast floors. Contrast still meets a11y.
 *   · Breathing timer (the central concentric-circles SVG), drift glow,
 *     blinking caret on the in-progress scrying line.
 *   · Reduced-motion tames all three animations.
 *   · Captures a quick scrying note → writes an entry. Real persistence
 *     wires up with the entry composer.
 *
 * Self-contained palette (does not use the public-site --bg / --ink
 * tokens) because Trance is a working **mode**, not the chrome's theme.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Trance — scrying</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cardo:ital,wght@0,400;0,700;1,400&family=Inria+Sans:wght@300;400&family=JetBrains+Mono:wght@400&family=Noto+Sans+Symbols&display=swap"
    />
    <style>
      :root {
        --tbg: #0b0806;
        --tbg2: #120c08;
        --amber: #c9925a;
        --amber-soft: #7a5a38;
        --amber-dim: #4e3c28;
        --ember: #8a4a33;
        --font-display: "Cardo", serif;
        --font-ui: "Inria Sans", sans-serif;
        --font-mono: "JetBrains Mono", monospace;
        --font-glyph: "Noto Sans Symbols", "Cardo", serif;
      }
      * { box-sizing: border-box; }
      body { margin: 0; -webkit-font-smoothing: antialiased; }
      button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
      :focus-visible { outline: 1px solid var(--amber); outline-offset: 3px; }

      @keyframes breathe {
        0%, 100% { transform: scale(1);    opacity: .55; }
        50%       { transform: scale(1.05); opacity: .85; }
      }
      @keyframes drift {
        0%, 100% { opacity: .4;  }
        50%       { opacity: .75; }
      }
      @keyframes blink { 50% { opacity: 0; } }

      .breathe { animation: breathe 7s ease-in-out infinite; transform-origin: center; }
      .drift   { animation: drift 5s ease-in-out infinite; }
      .tcaret  { animation: blink 1.3s step-end infinite; }

      @media (prefers-reduced-motion: reduce) {
        .breathe, .drift, .tcaret { animation: none; }
      }

      .control-end:hover,
      .control-dim:hover { color: var(--amber) !important; }
      .control-pause:hover { border-color: var(--amber-soft) !important; }
    </style>
  </head>
  <body>
    <div style="height:100vh;background:radial-gradient(ellipse at 50% 42%, var(--tbg2), var(--tbg) 70%);color:var(--amber);font-family:var(--font-display);display:flex;flex-direction:column;overflow:hidden;position:relative">

      <!-- vignette -->
      <div style="position:absolute;inset:0;pointer-events:none;box-shadow:inset 0 0 220px 60px rgba(0,0,0,.7)"></div>

      <!-- top bar -->
      <div style="display:flex;align-items:center;justify-content:space-between;padding:22px 30px;position:relative;z-index:2">
        <div style="display:flex;align-items:center;gap:12px;font-family:var(--font-ui);font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--amber-soft)">
          <svg width="18" height="18" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <circle cx="20" cy="20" r="17.5" stroke="var(--amber-soft)" stroke-width="1.4"></circle>
            <line x1="9.5" y1="20" x2="30.5" y2="20" stroke="var(--amber-soft)" stroke-width="1.4"></line>
          </svg>
          Trance · scrying
        </div>
        <div data-trance-clock style="font-family:var(--font-mono);font-size:13px;color:var(--amber-soft);letter-spacing:.1em">12:48</div>
      </div>

      <!-- center -->
      <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 30px;position:relative;z-index:2;min-height:0">
        <div style="position:relative;width:260px;height:260px;display:flex;align-items:center;justify-content:center;margin-bottom:18px">
          <svg class="breathe" viewBox="0 0 200 200" width="260" height="260" style="position:absolute;inset:0" aria-hidden="true">
            <circle cx="100" cy="100" r="92" fill="none" stroke="var(--amber-dim)" stroke-width="1"></circle>
            <circle cx="100" cy="100" r="74" fill="none" stroke="var(--amber-dim)" stroke-width=".8" opacity=".7"></circle>
            <circle cx="100" cy="100" r="48" fill="none" stroke="var(--amber-soft)" stroke-width=".8" opacity=".5"></circle>
          </svg>
          <div class="drift" style="width:120px;height:120px;border-radius:50%;background:radial-gradient(circle at 50% 45%, var(--ember), transparent 68%);display:flex;align-items:center;justify-content:center">
            <span style="font-family:var(--font-glyph);font-size:30px;color:var(--amber);opacity:.85">☽</span>
          </div>
        </div>

        <div style="max-width:680px;text-align:center">
          <div style="font-family:var(--font-ui);font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:var(--amber-dim);margin-bottom:20px">The black mirror · session III</div>
          <p style="font-family:var(--font-display);font-style:italic;font-size:clamp(22px,3.2vw,30px);line-height:1.6;color:var(--amber);margin:0;opacity:.92;text-wrap:pretty">A door of pale stone, half-open. Beyond it, water moving without sound — and a figure that will not yet turn its face<span class="tcaret" style="color:var(--ember)">▏</span></p>
        </div>
      </div>

      <!-- bottom controls -->
      <div style="display:flex;align-items:center;justify-content:center;gap:30px;padding:26px 30px 40px;position:relative;z-index:2">
        <button type="button" class="control-dim" aria-label="Dim" style="display:flex;align-items:center;gap:8px;color:var(--amber-soft);font-family:var(--font-ui);font-size:12px;letter-spacing:.1em;transition:color .15s ease">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="5"></circle><path d="M12 3v2M12 19v2M3 12h2M19 12h2" stroke-linecap="round"></path></svg>
        </button>
        <button type="button" data-trance-pause class="control-pause" aria-label="Pause timer" aria-pressed="false" style="display:flex;align-items:center;justify-content:center;width:60px;height:60px;border:1px solid var(--amber-dim);border-radius:50%;color:var(--amber);transition:border-color .15s ease">
          <span data-pause-icon>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M9 6v12M15 6v12"></path></svg>
          </span>
        </button>
        <button type="button" class="control-end" aria-label="End session" style="display:flex;align-items:center;gap:8px;color:var(--amber-soft);font-family:var(--font-ui);font-size:12px;letter-spacing:.1em;transition:color .15s ease">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"></path></svg>
          End
        </button>
      </div>

      <div style="position:absolute;bottom:14px;left:0;right:0;text-align:center;font-family:var(--font-ui);font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber-dim);z-index:2">Low-blue-light · ambient timer running · auto-saves to the record</div>
    </div>

    <script>
      // Live clock — replaces the placeholder "12:48" with the current
      // time, ticking each minute. Reduced-motion is honored by leaving
      // the animation declarations off (CSS handles that).
      const clockNode = document.querySelector("[data-trance-clock]");
      const renderClock = () => {
        if (!clockNode) return;
        const now = new Date();
        const hh = String(now.getHours()).padStart(2, "0");
        const mm = String(now.getMinutes()).padStart(2, "0");
        clockNode.textContent = `${hh}:${mm}`;
      };
      renderClock();
      setInterval(renderClock, 30 * 1000);

      // Pause toggle — flips the icon between pause and play. Real timer
      // wiring lands when the entry composer's scrying-note write target
      // ships.
      const PAUSE_SVG = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M9 6v12M15 6v12"></path></svg>`;
      const PLAY_SVG  = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 5l12 7-12 7z"></path></svg>`;
      const pauseBtn = document.querySelector("[data-trance-pause]");
      const pauseIcon = document.querySelector("[data-pause-icon]");
      const breathe = document.querySelector(".breathe");
      const drift = document.querySelector(".drift");
      pauseBtn?.addEventListener("click", () => {
        const wasPaused = pauseBtn.getAttribute("aria-pressed") === "true";
        const nowPaused = !wasPaused;
        pauseBtn.setAttribute("aria-pressed", nowPaused ? "true" : "false");
        if (pauseIcon) pauseIcon.innerHTML = nowPaused ? PLAY_SVG : PAUSE_SVG;
        if (breathe) (breathe as HTMLElement).style.animationPlayState = nowPaused ? "paused" : "";
        if (drift) (drift as HTMLElement).style.animationPlayState = nowPaused ? "paused" : "";
      });
    </script>
  </body>
</html>
