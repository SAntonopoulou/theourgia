---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Theourgia">
  <main style="max-width: 720px; margin: 0 auto; padding: var(--space-8, 64px) var(--space-5, 24px);">
    <span
      style="font-family: var(--font-mono); font-size: var(--type-ui, 13px); letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-mute);"
    >
      v0 · Phase 02 · Batch 1
    </span>
    <h1
      style="font-family: var(--font-serif); font-size: var(--type-display, 40px); color: var(--ink); margin: 12px 0;"
    >
      Theourgia
    </h1>
    <p style="color: var(--ink-soft); font-family: var(--font-ui);">
      Open-source magickal journal CMS and full practitioner toolkit.
      The public site is a stub during foundation work — visit
      <a href="/foundations" style="color: var(--accent); text-decoration: underline;">
        /foundations
      </a>
      for the design-system smoke page.
    </p>
  </main>
</BaseLayout>
