      ],
      "title": "Active plugins",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" },
      "description": "HTTP requests per second by status code, 5-minute rate.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "id": 6,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" }, "editorMode": "code", "expr": "sum by (status) (rate(theourgia_http_requests_total[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "title": "Request rate by status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" },
      "description": "Latency quantiles across all routes from the theourgia_http_request_duration_seconds histogram.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "id": 7,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" }, "editorMode": "code", "expr": "histogram_quantile(0.50, sum by (le) (rate(theourgia_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" }, "editorMode": "code", "expr": "histogram_quantile(0.90, sum by (le) (rate(theourgia_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p90", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" }, "editorMode": "code", "expr": "histogram_quantile(0.99, sum by (le) (rate(theourgia_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "title": "Request latency (p50 / p90 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "theourgia-prometheus" },
