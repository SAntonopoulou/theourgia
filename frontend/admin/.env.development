# Local dev defaults for the admin SPA.
#
# Mock mode is on by default in dev — the SPA resolves the built-in
# fixtures locally without needing a running backend. Turn it off by
# setting VITE_THEOURGIA_API_MOCK=0 (or unset in a `.env.development.local`)
# and running the backend on the origin the Vite dev server proxies to.
#
# Prod builds do NOT read this file; the Dockerfile doesn't set the
# flag, so `mock` falls back to false → live network requests.
VITE_THEOURGIA_API_MOCK=1
