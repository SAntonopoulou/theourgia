              <circle cx="100" cy="40" r="2.4"></circle>
              <circle cx="146.91" cy="62.59" r="2.4"></circle>
              <circle cx="158.5" cy="113.35" r="2.4"></circle>
              <circle cx="126.03" cy="154.06" r="2.4"></circle>
