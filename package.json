{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "theourgia",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Theourgia — magickal journal CMS and full practitioner toolkit (workspace root)",
  "license": "AGPL-3.0-only",
  "author": "Soror Ευ. Α.",
  "homepage": "https://theourgia.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/SAntonopoulou/theourgia.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "frontend/*",
    "docs/site"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "build": "pnpm -r --filter ./frontend/* build",
    "docs:dev": "pnpm --filter @theourgia/docs dev",
    "docs:build": "pnpm --filter @theourgia/docs build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "neverBuiltDependencies": []
  }
}
