{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@theourgia/shared",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "description": "Theourgia shared design system, UI primitives, tokens, and i18n",
  "license": "AGPL-3.0-only",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "import": "./src/tokens/index.ts"
    },
    "./tokens/theourgia.tokens.css": "./src/tokens/theourgia.tokens.css",
    "./tokens/theourgia.shared.css": "./src/tokens/theourgia.shared.css",
    "./tokens/theourgia-icons.svg": "./src/tokens/theourgia-icons.svg",
    "./tokens/first-paint.js": "./src/tokens/first-paint.js",
    "./tokens/tailwind-preset": {
      "types": "./src/tokens/tailwind-preset.d.ts",
      "default": "./src/tokens/tailwind.preset.cjs"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "import": "./src/i18n/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "biome check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.1",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-interactions": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/test": "8.6.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/suncalc": "^1.9.2",
    "happy-dom": "^15.11.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.0",
    "typescript": "^5.7.2",
    "vite": "^8.1.0",
    "vitest": "^2.1.8"
  }
}
