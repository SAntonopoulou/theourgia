{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      "**/node_modules",
      "**/dist",
      "**/build",
      "**/.astro",
      "**/.next",
      "**/.svelte-kit",
      "**/.turbo",
      "**/.cache",
      "**/.vite",
      "**/coverage",
      "**/*.min.js",
      "**/*.min.css",
      "**/backend/**",
      "**/plan/**",
      "**/docs/adr/**",
      "**/pnpm-lock.yaml",
      "**/package-lock.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "useEditorconfig": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "useExhaustiveDependencies": "warn"
      },
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "useNodejsImportProtocol": "error",
        "useConst": "error",
        "useTemplate": "error",
        "useShorthandArrayType": "error",
        "useShorthandAssign": "error",
        "noNamespace": "error",
        "noNonNullAssertion": "warn"
      },
      "suspicious": {
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["warn", "error"]
          }
        },
        "noDebugger": "error",
        "noExplicitAny": "error",
        "noEmptyBlockStatements": "warn"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "fix": "safe",
          "options": {
            "functions": ["clsx", "cva", "cn", "twMerge"]
          }
        }
      },
      "performance": {
        "noAccumulatingSpread": "error"
      },
      "a11y": {
        "useKeyWithClickEvents": "error",
        "useValidAriaProps": "error",
        "useValidAriaValues": "error",
        "useSemanticElements": "warn",
        "useFocusableInteractive": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "indentWidth": 2,
      "trailingCommas": "none"
    },
    "parser": {
      "allowComments": true,
      "allowTrailingCommas": false
    }
  },
  "overrides": [
    {
      "include": ["frontend/shared/src/tokens/first-paint.js"],
      "linter": {
        "rules": {
          "style": {
            "noVar": "off",
            "useTemplate": "off"
          },
          "correctness": {
            "noInnerDeclarations": "off"
          }
        }
      }
    },
    {
      "include": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    }
  ]
}
