# Theourgia .gitattributes
# Normalize line endings, classify binary files, control diff/merge behavior.

# Auto-detect text files; normalize to LF on commit
* text=auto eol=lf

# Explicit text formats (force LF)
*.py             text eol=lf
*.pyi            text eol=lf
*.ts             text eol=lf
*.tsx            text eol=lf
*.js             text eol=lf
*.jsx            text eol=lf
*.mjs            text eol=lf
*.cjs            text eol=lf
*.astro          text eol=lf
*.svelte         text eol=lf
*.vue            text eol=lf
*.json           text eol=lf
*.jsonc          text eol=lf
*.json5          text eol=lf
*.yaml           text eol=lf
*.yml            text eol=lf
*.toml           text eol=lf
*.md             text eol=lf
*.mdx            text eol=lf
*.txt            text eol=lf
*.sh             text eol=lf
*.bash           text eol=lf
*.sql            text eol=lf
*.css            text eol=lf
*.scss           text eol=lf
*.html           text eol=lf
*.htm            text eol=lf
*.xml            text eol=lf
*.svg            text eol=lf
Dockerfile       text eol=lf
*.Dockerfile     text eol=lf
*.dockerfile     text eol=lf
Caddyfile        text eol=lf
*.Caddyfile      text eol=lf
justfile         text eol=lf
Justfile         text eol=lf
Makefile         text eol=lf
.gitignore       text eol=lf
.gitattributes   text eol=lf
.editorconfig    text eol=lf
.env.example     text eol=lf
.env.*.example   text eol=lf
LICENSE          text eol=lf
NOTICE           text eol=lf

# Lockfiles — text but mark as generated for diff display
package-lock.json    text eol=lf linguist-generated=true
pnpm-lock.yaml       text eol=lf linguist-generated=true
yarn.lock            text eol=lf linguist-generated=true
uv.lock              text eol=lf linguist-generated=true
poetry.lock          text eol=lf linguist-generated=true
Pipfile.lock         text eol=lf linguist-generated=true
Cargo.lock           text eol=lf linguist-generated=true

# Binary files — never diff, never modify
*.png            binary
*.jpg            binary
*.jpeg           binary
*.gif            binary
*.webp           binary
*.avif           binary
*.ico            binary
*.pdf            binary
*.epub           binary
*.mobi           binary
*.woff           binary
*.woff2          binary
*.ttf            binary
*.otf            binary
*.eot            binary
*.zip            binary
*.tar            binary
*.tgz            binary
*.tar.gz         binary
*.gz             binary
*.bz2            binary
*.xz             binary
*.7z             binary
*.mp3            binary
*.mp4            binary
*.wav            binary
*.ogg            binary
*.flac           binary
*.opus           binary
*.webm           binary
*.mov            binary
*.so             binary
*.dylib          binary
*.dll            binary
*.exe            binary
*.bin            binary
*.dat            binary
# Swiss Ephemeris binary data files
*.se1            binary
*.se2            binary

# Astro / Vite build output (generated; don't diff)
dist/**          linguist-generated=true
build/**         linguist-generated=true
.astro/**        linguist-generated=true
.next/**         linguist-generated=true

# Plan / docs — language hints for GitHub linguist
plan/**          linguist-documentation
docs/**          linguist-documentation
